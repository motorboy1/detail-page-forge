    {
      "id": 161,
      "start": 445.76,
      "end": 447.76,
      "text": " 좀 신기한 느낌이 나고 있습니다."
    },
    {
      "id": 162,
      "start": 448.76,
      "end": 450.76,
      "text": " 뭐 이렇게 넣어서"
    },
    {
      "id": 163,
      "start": 450.76,
      "end": 452.76,
      "text": " 뭐 자잘한 부분들에"
    },
    {
      "id": 164,
      "start": 452.76,
      "end": 455.76,
      "text": " 조금 더 신경을 써줄 수도 있을 것 같아요."
    },
    {
      "id": 165,
      "start": 455.76,
      "end": 456.76,
      "text": " 이렇게"
    },
    {
      "id": 166,
      "start": 457.76,
      "end": 459.76,
      "text": " 늘려주는 다음에"
    },
    {
      "id": 167,
      "start": 459.76,
      "end": 461.76,
      "text": " 여기쯤에다가"
    },
    {
      "id": 168,
      "start": 461.76,
      "end": 462.76,
      "text": " 이렇게"
    },
    {
      "id": 169,
      "start": 462.76,
      "end": 465.76,
      "text": " 여기를 확 줄여도"
    },
    {
      "id": 170,
      "start": 465.76,
      "end": 467.76,
      "text": " 이렇게 넣어줄 수도 있을 것 같고"
    },
    {
      "id": 171,
      "start": 467.76,
      "end": 469.76,
      "text": " 자, 이거랑 이제"
    },
    {
      "id": 172,
      "start": 469.76,
      "end": 471.76,
      "text": " 이런 게 그림자가 없는"
    },
    {
      "id": 173,
      "start": 471.76,
      "end": 473.76,
      "text": " 거전도 한번 실험을 해받을 것 같아서"
    },
    {
      "id": 174,
      "start": 473.76,
      "end": 476.76,
      "text": " 자, 이렇게 업세준 다음에 한 번 봐볼게요."
    },
    {
      "id": 175,
      "start": 476.76,
      "end": 478.76,
      "text": " 여기다 업세주고"
    },
    {
      "id": 176,
      "start": 478.76,
      "end": 481.76,
      "text": " 업세주고 100경 색깔을 적당하게"
    },
    {
      "id": 177,
      "start": 481.76,
      "end": 483.76,
      "text": " 좀 조절해서"
    },
    {
      "id": 178,
      "start": 489.76,
      "end": 490.76,
      "text": " 이런 식으로 이렇게"
    },
    {
      "id": 179,
      "start": 490.76,
      "end": 493.76,
      "text": " L로로 넣는 것도 재미가 있어 보이는데"
    },
    {
      "id": 180,
      "start": 493.76,
      "end": 494.76,
      "text": " 이렇게"
    },
    {
      "id": 181,
      "start": 495.76,
      "end": 496.76,
      "text": " Y로로 넣고"
    },
    {
      "id": 182,
      "start": 496.76,
      "end": 497.76,
      "text": " 여기를"
    },
    {
      "id": 183,
      "start": 497.76,
      "end": 499.76,
      "text": " Blackrood 맵도 L로랑"
    },
    {
      "id": 184,
      "start": 499.76,
      "end": 501.76,
      "text": " 조합이 괜찮겠죠?"
    },
    {
      "id": 185,
      "start": 501.76,
      "end": 503.76,
      "text": " 자, 이런 식으로"
    },
    {
      "id": 186,
      "start": 503.76,
      "end": 504.76,
      "text": " 어, 이런 식으로 가는 것도"
    },
    {
      "id": 187,
      "start": 504.76,
      "end": 506.76,
      "text": " 갱춘해보입니다."
    },
    {
      "id": 188,
      "start": 507.76,
      "end": 509.76,
      "text": " 이렇게"
    },
    {
      "id": 189,
      "start": 509.76,
      "end": 510.76,
      "text": " 어, 좋습니다."
    },
    {
      "id": 190,
      "start": 510.76,
      "end": 512.76,
      "text": " 이렇게 하면 약간 스티커드 느낌도 나면서"
