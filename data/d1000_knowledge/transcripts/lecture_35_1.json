    {
      "id": 191,
      "start": 512.76,
      "end": 513.76,
      "text": " 조금 더"
    },
    {
      "id": 192,
      "start": 513.76,
      "end": 515.76,
      "text": " 한 대적인 느낌이 좀 나네요."
