    {
      "id": 224,
      "start": 586.76,
      "end": 587.76,
      "text": " 뜬 거 없는"
    },
    {
      "id": 225,
      "start": 587.76,
      "end": 588.76,
      "text": " 되게 의미없어 보이는"
    },
    {
      "id": 226,
      "start": 588.76,
      "end": 590.76,
      "text": " 향을 좀 써주는 거예요."
    },
    {
      "id": 227,
      "start": 591.76,
      "end": 593.76,
