    {
      "id": 193,
      "start": 515.76,
      "end": 516.76,
      "text": " 좋습니다."
    },
    {
      "id": 194,
      "start": 516.76,
      "end": 518.76,
      "text": " 그럼 여기서 L로를 살짝 이렇게"
