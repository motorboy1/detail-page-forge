    {
      "id": 216,
      "start": 563.76,
      "end": 564.76,
      "text": " 집사님,"
    },
    {
      "id": 217,
      "start": 565.76,
      "end": 567.76,
      "text": " 옆으로 이렇게 좀"
    },
    {
      "id": 218,
      "start": 572.76,
      "end": 573.76,
      "text": " 띄는 것에"
    },
    {
      "id": 219,
      "start": 573.76,
      "end": 575.76,
      "text": " 7중적 맨날을"
    },
    {
      "id": 220,
      "start": 577.76,
      "end": 578.76,
      "text": " 돈을"
    },
    {
      "id": 221,
      "start": 578.76,
      "end": 579.76,
      "text": " 돈을"
    },
    {
      "id": 222,
      "start": 579.76,
      "end": 580.76,
      "text": " 채워갑니다."
