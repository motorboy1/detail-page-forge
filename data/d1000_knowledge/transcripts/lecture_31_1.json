    {
      "id": 227,
      "start": 689.12,
      "end": 692.32,
      "text": " 어 국내 주주의"
    },
    {
      "id": 228,
      "start": 692.32,
      "end": 694.32,
      "text": " 에스프레스"
    },
    {
      "id": 229,
      "start": 694.32,
      "end": 697.12,
      "text": " 에스프레스"
    },
    {
      "id": 230,
