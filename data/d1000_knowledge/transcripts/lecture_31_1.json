    {
      "id": 153,
      "start": 478.52,
      "end": 480.52,
      "text": " 40 이렇게 맞춰주고"
    },
    {
      "id": 154,
      "start": 482.12,
      "end": 484.12,
      "text": " 자 좋습니다"
    },
    {
      "id": 155,
      "start": 484.12,
      "end": 486.12,
      "text": " 자 여기서 약간 기교를 좀 부려볼까요"
