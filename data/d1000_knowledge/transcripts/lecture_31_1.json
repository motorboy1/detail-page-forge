      "end": 432.12,
      "text": " 자"
    },
    {
      "id": 136,
      "start": 434.12,
      "end": 436.12,
      "text": " 유리시스"
    },
    {
      "id": 137,
      "start": 436.12,
      "end": 438.12,
      "text": " 에스프레스"
    },
    {
      "id": 138,
      "start": 440.12,
      "end": 441.12,
      "text": " 자 이렇게"
