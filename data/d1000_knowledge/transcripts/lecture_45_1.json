    {
      "id": 128,
      "start": 303.76,
      "end": 305.04,
      "text": " 전직"
    },
    {
      "id": 129,
      "start": 305.04,
      "end": 307.68,
      "text": " CIA에 출신"
    },
    {
      "id": 130,
      "start": 307.68,
      "end": 310.24,
      "text": " 국장이 말한"
    },
    {
      "id": 131,
      "start": 310.24,
      "end": 312.0,
      "text": " 이 세상에"
    },
    {
      "id": 132,
      "start": 312.0,
      "end": 313.0,
      "text": " 이 세상에"
    },
    {
      "id": 133,
      "start": 313.0,
      "end": 315.16,
      "text": " 음모론과"
    },
    {
      "id": 134,
      "start": 315.16,
      "end": 316.36,
      "text": " 현실"
    },
    {
      "id": 135,
      "start": 316.36,
      "end": 319.2,
      "text": " 그 사이"
    },
    {
      "id": 136,
      "start": 319.2,
      "end": 321.36,
      "text": " 어딘가에"
    },
    {
      "id": 137,
      "start": 321.36,
      "end": 325.16,
      "text": " 하묻진 이야기들"
    },
    {
      "id": 138,
      "start": 325.16,
      "end": 326.92,
      "text": " 이것을 다시"
    },
    {
      "id": 139,
      "start": 326.92,
      "end": 328.12,
      "text": " 한 번"
    },
    {
      "id": 140,
      "start": 328.12,
      "end": 331.08000000000004,
      "text": " 잘 펴보았어야 합니다"
    },
    {
      "id": 141,
      "start": 331.08000000000004,
      "end": 333.44,
      "text": " 며느�식으로 간단하게 텍트를 써주는 거예요"
    },
    {
      "id": 142,
      "start": 333.44,
      "end": 336.24,
      "text": " 자, 요한이 24 정도 크기로 좀 늘려주고"
    },
    {
      "id": 143,
      "start": 336.24,
      "end": 337.72,
      "text": " 자, 그 다음에 얘를"
    },
    {
      "id": 144,
      "start": 337.72,
      "end": 340.24,
      "text": " 어떻게 배치하냐?를 잘 따라오세요"
    },
    {
      "id": 145,
      "start": 340.24,
      "end": 341.0,
      "text": " 자, 얘를 이렇게"
    },
    {
      "id": 146,
      "start": 341.0,
      "end": 341.84000000000003,
      "text": " 갖고 와서"
    },
    {
      "id": 147,
      "start": 341.84000000000003,
      "end": 343.12,
      "text": " 여기다가 넣는 거예요"
    },
    {
      "id": 148,
      "start": 343.12,
      "end": 343.96000000000004,
      "text": " 재밌죠?"
    },
    {
      "id": 149,
      "start": 343.96000000000004,
      "end": 344.76,
      "text": " 여기다 넣으면은"
