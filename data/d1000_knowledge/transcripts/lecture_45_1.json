    {
      "id": 125,
      "start": 293.96000000000004,
      "end": 295.20000000000005,
      "text": " 숨겨온"
    },
    {
      "id": 126,
      "start": 296.68,
      "end": 298.68,
      "text": " 미국과 전 세계"
    },
    {
      "id": 127,
      "start": 298.68,
      "end": 302.92,
      "text": " 극비 비밀리스트를 공개합니다"
