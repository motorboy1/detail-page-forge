    {
      "id": 182,
      "start": 547.9,
      "end": 549.9,
      "text": " 자고"
    },
    {
      "id": 183,
      "start": 551.9,
      "end": 552.9,
      "text": " 운영시간"
    },
    {
      "id": 184,
      "start": 552.9,
      "end": 554.9,
      "text": " 운영시간 이제"
