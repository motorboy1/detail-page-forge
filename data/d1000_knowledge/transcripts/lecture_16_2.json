    {
      "id": 157,
      "start": 459.20000000000005,
      "end": 461.20000000000005,
      "text": " 32정도"
    },
    {
      "id": 158,
      "start": 461.20000000000005,
      "end": 465.20000000000005,
      "text": " 오 위치"
    },
    {
      "id": 159,
      "start": 465.20000000000005,
      "end": 468.40000000000003,
      "text": " 아 얘는 위치로 삼가요"
    },
    {
      "id": 160,
      "start": 468.40000000000003,
      "end": 471.90000000000003,
      "text": " 4번 줄고"
    },
    {
      "id": 161,
      "start": 471.90000000000003,
