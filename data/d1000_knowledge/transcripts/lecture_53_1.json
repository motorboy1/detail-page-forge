    {
      "id": 112,
      "start": 345.7,
      "end": 348.7,
      "text": " 빌자들을 난발해주고요."
    },
    {
      "id": 113,
      "start": 352.7,
      "end": 355.7,
      "text": " 자 이 배경색은 다시 옐로우로 깔맞춤."
    },
    {
      "id": 114,
      "start": 355.7,
      "end": 357.7,
      "text": " 여기 안에 있는 색상들은"
    },
    {
      "id": 115,
      "start": 360.7,
      "end": 361.5,
      "text": " 이렇게"
    },
    {
      "id": 116,
      "start": 361.5,
      "end": 362.5,
      "text": " 이렇게"
    },
    {
      "id": 117,
      "start": 362.5,
      "end": 363.5,
      "text": " 이렇게"
    },
    {
      "id": 118,
      "start": 363.5,
      "end": 364.5,
      "text": " 전혀 또 의미를 알 수 없는"
    },
    {
      "id": 119,
      "start": 364.5,
      "end": 366.7,
      "text": " 빌자들을 난발해주고요."
    },
    {
      "id": 120,
      "start": 366.7,
      "end": 369.7,
      "text": " 이렇게 또는 다시 옐로우로 깔맞춤."
    },
    {
      "id": 121,
      "start": 369.7,
      "end": 371.7,
      "text": " 여기 안에 있는 색상들은"
