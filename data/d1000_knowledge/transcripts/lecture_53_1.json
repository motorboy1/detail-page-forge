    {
      "id": 73,
      "start": 252.1,
      "end": 252.7,
      "text": " 그렇죠."
    },
    {
      "id": 74,
      "start": 252.7,
      "end": 254.89999999999998,
      "text": " 이런 데에 딱 들어가면 될 것 같아요."
