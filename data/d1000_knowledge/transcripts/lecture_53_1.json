    {
      "id": 56,
      "start": 194.10000000000002,
      "end": 195.10000000000002,
      "text": " 오케이"
    },
    {
      "id": 57,
      "start": 197.3,
      "end": 198.70000000000002,
      "text": " 디스톱이야"
    },
    {
      "id": 58,
      "start": 200.70000000000002,
      "end": 201.9,
      "text": " 디스톱이야"
    },
    {
      "id": 59,
      "start": 204.5,
      "end": 205.9,
      "text": " 법륜수님"
    },
    {
      "id": 60,
      "start": 212.10000000000002,
      "end": 213.5,
      "text": " 행복에 대한"
    },
    {
      "id": 61,
      "start": 221.10000000000002,
      "end": 221.9,
      "text": " 듣가"
    },
    {
      "id": 62,
      "start": 225.10000000000002,
      "end": 227.9,
      "text": " 자 뭐 디스톱이야 법륜수님이랑 게 있다고 치..."
