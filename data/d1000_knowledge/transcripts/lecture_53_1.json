    {
      "id": 143,
      "start": 424.7,
      "end": 426.7,
      "text": " 마이너스 80"
    },
    {
      "id": 144,
      "start": 426.7,
      "end": 428.7,
      "text": " 파이너스 80이 좋아 보이네요."
    },
    {
      "id": 145,
      "start": 428.7,
      "end": 429.7,
      "text": " 자 이렇게 해주고"
    },
    {
      "id": 146,
      "start": 429.7,
      "end": 431.7,
      "text": " 다시 조항 정렬 해주시면 됩니다."
    },
    {
      "id": 147,
      "start": 431.7,
      "end": 433.7,
      "text": " 이렇게 조항 정렬."
    },
    {
      "id": 148,
      "start": 433.7,
      "end": 434.7,
      "text": " 어?"
    },
    {
      "id": 149,
      "start": 434.7,
      "end": 436.7,
      "text": " 딱 있었는데 조항 정렬이"
    },
    {
      "id": 150,
      "start": 436.7,
      "end": 438.7,
      "text": " 조항 정렬"
    },
    {
      "id": 151,
      "start": 438.7,
      "end": 440.7,
      "text": " 여기가 조항 정렬이고"
    },
    {
      "id": 152,
      "start": 440.7,
      "end": 441.7,
      "text": " 얘도"
    },
    {
      "id": 153,
      "start": 441.7,
      "end": 443.7,
      "text": " 유친구의 조항 정렬."
    },
    {
      "id": 154,
      "start": 443.7,
      "end": 444.7,
      "text": " 얘도"
    },
    {
      "id": 155,
      "start": 444.7,
      "end": 445.7,
      "text": " 유친구의 조항 정렬이 좋습니다."
    },
    {
      "id": 156,
      "start": 445.7,
      "end": 446.7,
      "text": " 이렇게 하면"
    },
    {
      "id": 157,
      "start": 446.7,
      "end": 448.7,
      "text": " 약간 로고 같은 느낌이 등장하면서"
    },
    {
      "id": 158,
      "start": 448.7,
      "end": 451.7,
      "text": " 딱 여기 조형선을 잡아주게 되죠."
    },
    {
      "id": 159,
      "start": 451.7,
      "end": 453.7,
      "text": " 위에까지는 좋아요."
    },
    {
      "id": 160,
      "start": 453.7,
      "end": 455.7,
      "text": " 좋은데"
    },
    {
      "id": 161,
      "start": 455.7,
      "end": 459.7,
      "text": " 이제 가운데를 어떻게 꾸릴 것인가"
    },
    {
      "id": 162,
      "start": 459.7,
      "end": 460.7,
      "text": " 자"
    },
    {
      "id": 163,
      "start": 460.7,
      "end": 462.7,
      "text": " 여기를 좀 알아볼 건데요."
    },
    {
      "id": 164,
      "start": 462.7,
      "end": 465.7,
      "text": " 자 이 픽셀 넣기는 사실"
    },
    {
      "id": 165,
      "start": 465.7,
      "end": 468.7,
      "text": " 자 저희가 지금까지 알아본 디자인이 다 그렇듯"
    },
    {
      "id": 166,
      "start": 468.7,
      "end": 471.7,
      "text": " 사실 디자인이 뭐 그렇게 내용을 꼭"
    },
    {
      "id": 167,
      "start": 471.7,
      "end": 473.7,
      "text": " 잘 드러내야 된다고 생각을 하시면"
    },
    {
      "id": 168,
      "start": 473.7,
      "end": 475.7,
      "text": " 조금 구시되적인 발상입니다."
    },
    {
      "id": 169,
      "start": 475.7,
      "end": 477.7,
      "text": " 자 요즘 디자인은 어떻게 하는 거냐"
    },
    {
      "id": 170,
      "start": 477.7,
      "end": 478.7,
      "text": " 그냥"
    },
    {
      "id": 171,
      "start": 478.7,
      "end": 480.7,
      "text": " 그냥 하는 거예요."
    },
    {
      "id": 172,
      "start": 480.7,
      "end": 482.7,
      "text": " 자 보여드릴게요."
    },
    {
      "id": 173,
      "start": 482.7,
      "end": 483.7,
      "text": " 자"
    },
    {
      "id": 174,
      "start": 483.7,
      "end": 484.7,
      "text": " 4학형"
    },
    {
      "id": 175,
      "start": 484.7,
      "end": 485.7,
      "text": " 4에"
    },
    {
      "id": 176,
      "start": 485.7,
      "end": 486.7,
      "text": " 8에 뵙으로 넣을게요."
    },
    {
      "id": 177,
      "start": 486.7,
      "end": 487.7,
      "text": " 320에"
    },
    {
      "id": 178,
      "start": 487.7,
      "end": 488.7,
      "text": " 120"
    },
    {
      "id": 179,
      "start": 488.7,
      "end": 490.7,
      "text": " 자 8에 뵙으로 넣어주고"
    },
    {
      "id": 180,
      "start": 490.7,
      "end": 492.7,
      "text": " 얘를 다 엘로우로 맞춰준 다음에"
    },
    {
      "id": 181,
      "start": 492.7,
      "end": 493.7,
      "text": " 자 이 다음에"
    },
    {
      "id": 182,
      "start": 493.7,
      "end": 496.7,
      "text": " 8고파기 8자니즈를 하나 만들어줄 거예요."
    },
    {
      "id": 183,
      "start": 496.7,
      "end": 499.7,
      "text": " 8고파이 넣은 8이 너무 작으니까 16고파이 16."
    },
    {
      "id": 184,
      "start": 499.7,
      "end": 500.7,
      "text": " 자 그리고"
    },
    {
      "id": 185,
      "start": 500.7,
      "end": 501.7,
      "text": " 이제"
    },
    {
      "id": 186,
      "start": 501.7,
      "end": 502.7,
      "text": " 여기 주의로"
    },
    {
      "id": 187,
      "start": 502.7,
      "end": 504.7,
      "text": " 유친구들이"
    },
    {
      "id": 188,
      "start": 504.7,
      "end": 506.7,
      "text": " 약간 뻗어나가게 만들어 볼 거거든요."
    },
    {
      "id": 189,
      "start": 506.7,
      "end": 507.7,
      "text": " 근데 얘가 좀 너무 기네요."
    },
    {
      "id": 190,
      "start": 507.7,
      "end": 508.7,
      "text": " 그러면"
    },
    {
      "id": 191,
      "start": 508.7,
      "end": 509.7,
      "text": " 320에"
    },
    {
      "id": 192,
      "start": 509.7,
      "end": 510.7,
      "text": " 4학식으로 쭉쭉"
    },
    {
      "id": 193,
      "start": 510.7,
      "end": 511.7,
      "text": " 자 이렇게"
    },
    {
      "id": 194,
      "start": 511.7,
      "end": 514.7,
      "text": " 이렇게 맞춰주는 거죠."
    },
    {
      "id": 195,
      "start": 514.7,
      "end": 515.7,
      "text": " 자 여기서 이제"
    },
    {
      "id": 196,
      "start": 515.7,
      "end": 516.7,
      "text": " 약간 얘네가"
    },
    {
      "id": 197,
      "start": 516.7,
      "end": 518.7,
      "text": " 바이러스가 뻗어나가듯이"
    },
    {
      "id": 198,
      "start": 518.7,
      "end": 520.7,
      "text": " 뻗어나가게 배치를 해줍니다."
    },
    {
      "id": 199,
      "start": 520.7,
      "end": 521.7,
      "text": " 자"
    },
    {
      "id": 200,
      "start": 521.7,
      "end": 522.7,
      "text": " 저기 한남동 가면"
    },
    {
      "id": 201,
      "start": 522.7,
      "end": 523.7,
      "text": " 마음대로"
    },
    {
      "id": 202,
      "start": 523.7,
      "end": 524.7,
      "text": " 어플라인이라는"
    },
    {
      "id": 203,
      "start": 524.7,
      "end": 525.7,
      "text": " 빠가 있거든요."
    },
    {
      "id": 204,
      "start": 525.7,
      "end": 527.7,
      "text": " 아파인지 카페인지 암튼"
    },
    {
      "id": 205,
      "start": 527.7,
      "end": 529.7,
      "text": " 자 거기"
    },
    {
      "id": 206,
      "start": 529.7,
      "end": 530.7,
      "text": " 가시면 로고가"
    },
    {
      "id": 207,
      "start": 530.7,
      "end": 531.7,
      "text": " 이런 형태예요."
    },
    {
      "id": 208,
      "start": 531.7,
      "end": 533.7,
      "text": " 이런 형태인데"
    },
    {
      "id": 209,
      "start": 533.7,
      "end": 534.7,
      "text": " 자 일단"
    },
    {
      "id": 210,
      "start": 534.7,
      "end": 535.7,
      "text": " 이름부터"
    },
    {
      "id": 211,
      "start": 535.7,
      "end": 537.7,
      "text": " 마다 어플라인이"
    },
    {
      "id": 212,
      "start": 537.7,
      "end": 538.7,
      "text": " 무슨 뜻일까?"
    },
    {
      "id": 213,
      "start": 538.7,
      "end": 540.7,
      "text": " 근데 여기가 지금 한단동에서"
    },
    {
      "id": 214,
      "start": 540.7,
      "end": 541.7,
      "text": " 제일 그래도"
    },
    {
      "id": 215,
      "start": 541.7,
      "end": 542.7,
      "text": " 잘나가는 카페 중 하나거든요."
    },
    {
      "id": 216,
      "start": 542.7,
      "end": 543.7,
      "text": " 자 근데"
    },
    {
      "id": 217,
      "start": 543.7,
      "end": 544.7,
      "text": " 생각해봅시다."
    },
    {
      "id": 218,
      "start": 544.7,
      "end": 546.7,
      "text": " 마다 어플라인이 뭔데?"
    },
    {
      "id": 219,
      "start": 546.7,
      "end": 548.7,
      "text": " 근데 그걸 안 사람이 있을까요?"
    },
    {
      "id": 220,
      "start": 548.7,
      "end": 550.7,
      "text": " 지인 사람을 알 수도 있는데"
    },
    {
      "id": 221,
      "start": 550.7,
      "end": 551.7,
      "text": " 그러세요."
    },
    {
      "id": 222,
      "start": 551.7,
      "end": 553.7,
      "text": " 마다 어플라인이 무슨 뜻인지 알아야 되나?"
    },
    {
      "id": 223,
      "start": 553.7,
      "end": 554.7,
      "text": " 일단"
    },
    {
      "id": 224,
      "start": 554.7,
      "end": 555.7,
      "text": " 절대 몰라야 되죠."
    },
    {
      "id": 225,
      "start": 555.7,
      "end": 556.7,
      "text": " 자 그리고 로고도"
    },
    {
      "id": 226,
      "start": 556.7,
      "end": 557.7,
      "text": " 이런 식으로 돼 있어요."
    },
    {
      "id": 227,
      "start": 557.7,
      "end": 558.7,
      "text": " 이런 식으로"
    },
    {
      "id": 228,
      "start": 558.7,
      "end": 559.7,
      "text": " 픽셀들이"
    },
    {
      "id": 229,
      "start": 559.7,
      "end": 560.7,
      "text": " 그냥 모여있거든요."
    },
    {
      "id": 230,
      "start": 560.7,
      "end": 561.7,
      "text": " 뭐 이렇게 정확히"
    },
    {
      "id": 231,
      "start": 561.7,
      "end": 563.7,
      "text": " 어떤 의미가 있을 수도 있는데"
    },
    {
      "id": 232,
      "start": 563.7,
      "end": 564.7,
      "text": " 뭐 언뜻 봤을 때"
    },
    {
      "id": 233,
      "start": 564.7,
      "end": 565.7,
      "text": " 몰라요."
    },
    {
      "id": 234,
      "start": 565.7,
      "end": 566.7,
      "text": " 절대 모릅니다."
    },
    {
      "id": 235,
      "start": 566.7,
      "end": 567.7,
      "text": " 근데 그게"
    },
    {
      "id": 236,
      "start": 567.7,
      "end": 568.7,
      "text": " 왜 잘나갈까?"
    },
    {
      "id": 237,
      "start": 568.7,
      "end": 570.7,
      "text": " 그러니까 이 시대는"
    },
    {
      "id": 238,
      "start": 570.7,
      "end": 571.7,
      "text": " 더 이상"
    },
    {
      "id": 239,
      "start": 571.7,
      "end": 572.7,
      "text": " 디자인에서"
    },
    {
      "id": 240,
      "start": 572.7,
      "end": 574.7,
      "text": " 이해를 원하지 않는다는거에요."
    },
    {
      "id": 241,
      "start": 574.7,
      "end": 575.7,
      "text": " 오히려"
    },
    {
      "id": 242,
      "start": 575.7,
      "end": 577.7,
      "text": " 나보다 강한"
    },
    {
      "id": 243,
      "start": 577.7,
      "end": 578.7,
      "text": " 존재로서에"
    },
    {
      "id": 244,
      "start": 578.7,
      "end": 580.7,
      "text": " 그런 부을 가했음."
    },
    {
      "id": 245,
      "start": 580.7,
      "end": 581.7,
      "text": " 자 이런 거를"
    },
    {
      "id": 246,
      "start": 581.7,
      "end": 583.7,
      "text": " 좋아한다는거죠."
    },
    {
      "id": 247,
      "start": 583.7,
      "end": 585.7,
      "text": " 자 그게 뭐"
    },
    {
      "id": 248,
      "start": 585.7,
      "end": 587.7,
      "text": " 어떻게 보면 되게 역사적인 시대상과"
    },
    {
      "id": 249,
      "start": 587.7,
      "end": 589.7,
      "text": " 연관이 있을 수도 있는데"
    },
    {
      "id": 250,
      "start": 589.7,
      "end": 591.7,
      "text": " 아무튼 중요한거는"
    },
    {
      "id": 251,
      "start": 591.7,
      "end": 592.7,
      "text": " 지금 시대는"
    },
    {
      "id": 252,
      "start": 593.7,
      "end": 595.7,
      "text": " 나에게 설명해주는 존재를"
    },
    {
      "id": 253,
      "start": 595.7,
      "end": 597.7,
      "text": " 절대 좋아지 않는다."
    },
    {
      "id": 254,
      "start": 597.7,
      "end": 599.7,
      "text": " 그리고"
    },
    {
      "id": 255,
      "start": 599.7,
      "end": 601.7,
      "text": " 내가 이해할 수 없는 걸 좋아한다."
    },
    {
      "id": 256,
      "start": 601.7,
      "end": 603.7,
      "text": " 나보다 강해 보이는 것들."
    },
    {
      "id": 257,
      "start": 603.7,
      "end": 605.7,
      "text": " 자 이해할 수 없다는 것 자체가"
    },
    {
      "id": 258,
      "start": 605.7,
      "end": 606.7,
      "text": " 나보다 강하다한 거잖아요."
    },
    {
      "id": 259,
      "start": 606.7,
      "end": 608.7,
      "text": " 그냥 우리에게"
    },
    {
      "id": 260,
      "start": 608.7,
      "end": 610.7,
      "text": " 이해할 수 없는 책이 있다고 생각해봅시다."
    },
    {
      "id": 261,
      "start": 610.7,
      "end": 612.7,
      "text": " 자 두꺼운 이제"
    },
    {
      "id": 262,
      "start": 612.7,
      "end": 613.7,
      "text": " 수학과 원석인거죠."
    },
    {
      "id": 263,
      "start": 613.7,
      "end": 616.7,
      "text": " 수학과 대학원, 박사학생만 이해할 수 있는."
    },
    {
      "id": 264,
      "start": 616.7,
      "end": 617.7,
      "text": " 자 그런 걸 보면서"
    },
    {
      "id": 265,
      "start": 617.7,
      "end": 618.7,
      "text": " 우리는"
    },
    {
      "id": 266,
      "start": 618.7,
      "end": 619.7,
      "text": " 이게 우리의 부다"
    },
    {
      "id": 267,
      "start": 619.7,
      "end": 621.7,
      "text": " 강하다 라고 당이 느끼겠죠."
    },
    {
      "id": 268,
      "start": 622.7,
      "end": 623.7,
      "text": " 당연히 어려우니까"
    },
    {
      "id": 269,
      "start": 626.7,
      "end": 627.7,
      "text": " 자 근데 이제"
    },
    {
      "id": 270,
      "start": 628.7,
      "end": 629.7,
      "text": " 반대로"
    },
    {
      "id": 271,
      "start": 629.7,
      "end": 630.7,
      "text": " 되게 쉬운"
    },
    {
      "id": 272,
      "start": 630.7,
      "end": 631.7,
      "text": " 유치원 용책"
    },
    {
      "id": 273,
      "start": 631.7,
      "end": 632.7,
      "text": " 누구나 읽을 수 있는."
    },
    {
      "id": 274,
      "start": 632.7,
      "end": 634.7,
      "text": " 이런 거 보고 강하다 고 생각은 안 하잖아요."
    },
    {
      "id": 275,
      "start": 634.7,
      "end": 635.7,
      "text": " 그렇죠."
    },
    {
      "id": 276,
      "start": 635.7,
      "end": 637.7,
      "text": " 자 그런 차이인데"
    },
    {
      "id": 277,
      "start": 637.7,
      "end": 638.7,
      "text": " 아무튼 그래서"
    },
    {
      "id": 278,
      "start": 638.7,
      "end": 640.7,
      "text": " 이해하기 어려운게 강하다 인식을 주고"
    },
    {
      "id": 279,
      "start": 640.7,
      "end": 643.7,
      "text": " 우리의 지금 시대는 강한 것을"
    },
    {
      "id": 280,
      "start": 643.7,
      "end": 644.7,
      "text": " 요가고 있기 때문에"
    },
    {
      "id": 281,
      "start": 644.7,
      "end": 646.7,
      "text": " 이런식으로"
    },
    {
      "id": 282,
      "start": 646.7,
      "end": 648.7,
      "text": " 디자인도 강하게 가야 된다."
    },
    {
      "id": 283,
      "start": 648.7,
      "end": 650.7,
      "text": " 자 이런식으로 그냥 가운데"
    },
    {
      "id": 284,
      "start": 650.7,
      "end": 652.7,
      "text": " 그냥 뜬금없는 얼룩을 하 넣어주는 거예요."
    },
    {
      "id": 285,
      "start": 652.7,
      "end": 653.7,
      "text": " 좀 크기를 키워 보죠."
    },
    {
      "id": 286,
      "start": 653.7,
      "end": 655.7,
      "text": " 자 지혜한 다음에"
    },
    {
      "id": 287,
      "start": 655.7,
      "end": 656.7,
      "text": " 일정은"
    },
    {
      "id": 288,
      "start": 656.7,
      "end": 657.7,
      "text": " 크기 키우니까 더 좋네요."
    },
    {
      "id": 289,
      "start": 657.7,
      "end": 658.7,
      "text": " 자 키웠는데"
    },
    {
      "id": 290,
      "start": 658.7,
      "end": 659.7,
      "text": " 도저히 이게 왜 있는지?"
    },
    {
      "id": 291,
      "start": 659.7,
      "end": 660.7,
      "text": " 아무도 모르죠."
    },
    {
      "id": 292,
      "start": 660.7,
      "end": 662.7,
      "text": " 네 저도 모르고"
    },
    {
      "id": 293,
      "start": 662.7,
      "end": 663.7,
      "text": " 아무도 알 필요가 없습니다."
    },
    {
      "id": 294,
      "start": 663.7,
      "end": 665.7,
      "text": " 자 이런 걸 잘 생각해야 돼요."
    },
    {
      "id": 295,
      "start": 665.7,
      "end": 667.7,
      "text": " 아무도 알 필요가 없다."
    },
    {
      "id": 296,
      "start": 667.7,
      "end": 668.7,
      "text": " 여기 로고가 조금"
    },
    {
      "id": 297,
      "start": 668.7,
      "end": 671.7,
      "text": " 약간 시선이 분산된 느낌이 있어서"
    },
    {
      "id": 298,
      "start": 671.7,
      "end": 672.7,
      "text": " 얘를 빼주고요."
    },
    {
      "id": 299,
      "start": 673.7,
      "end": 675.7,
      "text": " 자 여기를 빼주고"
    },
    {
      "id": 300,
      "start": 680.7,
      "end": 682.7,
      "text": " 이거를 잘 좀 배치려볼게요."
    },
    {
      "id": 301,
      "start": 685.7,
      "end": 687.7,
      "text": " 이 정도로 잘 컷트해서"
    },
    {
      "id": 302,
      "start": 697.7,
      "end": 699.7,
      "text": " 내려주고"
    },
    {
      "id": 303,
      "start": 703.7,
      "end": 704.7,
      "text": " 자"
    },
    {
      "id": 304,
      "start": 711.7,
      "end": 713.7,
      "text": " 그리고 이 부분을"
    },
    {
      "id": 305,
      "start": 713.7,
      "end": 715.7,
      "text": " 자 이렇게 해야 배치만 해줘도"
    },
    {
      "id": 306,
      "start": 715.7,
      "end": 717.7,
      "text": " 얘는 어느정도"
    },
    {
      "id": 307,
      "start": 717.7,
      "end": 718.7,
      "text": " 그리고 아까 그"
    },
    {
      "id": 308,
      "start": 718.7,
      "end": 720.7,
      "text": " 법 룬스님이라고 썼던 거 하려고"
    },
    {
      "id": 309,
      "start": 720.7,
      "end": 722.7,
      "text": " 여기 작게 한번 써줄게요."
    },
    {
      "id": 310,
      "start": 722.7,
      "end": 724.7,
      "text": " 법 룬스"
    },
    {
      "id": 311,
      "start": 726.7,
      "end": 728.7,
      "text": " 하고 갑자기 이제 저랗고 on기후"
    },
    {
      "id": 312,
      "start": 728.7,
      "end": 729.7,
      "text": " 자 여기 이런 것도"
    },
    {
      "id": 313,
      "start": 729.7,
      "end": 730.7,
      "text": " 이런 저작공기후 나오는 것도"
    },
    {
      "id": 314,
      "start": 730.7,
      "end": 732.7,
      "text": " 되게 이상하잖아요."
    },
    {
      "id": 315,
      "start": 732.7,
      "end": 734.7,
      "text": " 사실 우리가 아는"
    },
    {
      "id": 316,
      "start": 734.7,
      "end": 736.7,
      "text": " 그 상식에 맞지 않죠?"
    },
    {
      "id": 317,
      "start": 736.7,
      "end": 738.7,
      "text": " 왜냐하면 저작권이 뭐가 있다고 그렇게"
    },
    {
      "id": 318,
      "start": 738.7,
      "end": 740.7,
      "text": " 근데 중요한 건 그게 아니라"
    },
    {
      "id": 319,
      "start": 740.7,
      "end": 742.7,
      "text": " 그냥 불가의성을"
    },
    {
      "id": 320,
      "start": 742.7,
      "end": 744.7,
      "text": " 연출하는 게"
    },
    {
      "id": 321,
      "start": 744.7,
      "end": 746.7,
      "text": " 요즘에 트렌드다."
    },
    {
      "id": 322,
      "start": 750.7,
      "end": 752.7,
      "text": " 자 이렇게 해주고 가운데"
    },
    {
      "id": 323,
      "start": 752.7,
      "end": 753.7,
      "text": " 여기 들어가면은"
    },
    {
      "id": 324,
      "start": 753.7,
      "end": 754.7,
      "text": " 굉장히 갑자기"
    },
    {
      "id": 325,
      "start": 754.7,
      "end": 755.7,
      "text": " 있어보인다."
    },
    {
      "id": 326,
      "start": 755.7,
      "end": 757.7,
      "text": " 자 뭐 이렇게 들어갔으니까"
    },
    {
      "id": 327,
      "start": 757.7,
      "end": 759.7,
      "text": " 이런 요소들이"
    },
    {
      "id": 328,
      "start": 759.7,
      "end": 761.7,
      "text": " 뭐 드문 드문 이렇게"
    },
    {
      "id": 329,
      "start": 761.7,
      "end": 763.7,
      "text": " 이렇게 빈공간들 같이 보이는 곳들에요."
    },
    {
      "id": 330,
      "start": 763.7,
      "end": 765.7,
      "text": " 약간 하나씩"
    },
    {
      "id": 331,
      "start": 765.7,
      "end": 766.7,
      "text": " 약간 친구처럼"
    },
    {
      "id": 332,
      "start": 766.7,
      "end": 768.7,
      "text": " 조금 더 더 들어가도"
    },
    {
      "id": 333,
      "start": 768.7,
      "end": 770.7,
      "text": " 괜춘하겠죠?"
    },
    {
      "id": 334,
      "start": 774.7,
      "end": 776.7,
      "text": " 자 뭐 이런 식으로"
    },
    {
      "id": 335,
      "start": 776.7,
      "end": 778.7,
      "text": " 알 수 없는 위치에"
    },
    {
      "id": 336,
      "start": 778.7,
      "end": 780.7,
      "text": " 자 여기도 갑자기 하나"
    },
    {
      "id": 337,
      "start": 780.7,
      "end": 782.7,
      "text": " 이렇게 들어가주고"
    },
    {
      "id": 338,
      "start": 782.7,
      "end": 784.7,
      "text": " 이런 데도 뭐"
    },
    {
      "id": 339,
      "start": 784.7,
      "end": 785.7,
      "text": " 가끔씩"
    },
    {
      "id": 340,
      "start": 785.7,
      "end": 786.7,
      "text": " 한두개씩"
    },
    {
      "id": 341,
      "start": 786.7,
      "end": 788.7,
      "text": " 이렇게"
    },
    {
      "id": 342,
      "start": 788.7,
      "end": 790.7,
      "text": " 한두개씩 들어가주는 센스"
    },
    {
      "id": 343,
      "start": 796.7,
      "end": 798.7,
      "text": " 이렇게"
    },
    {
      "id": 344,
      "start": 798.7,
      "end": 800.7,
      "text": " 자 특자에다도 살짝 붙여볼까요?"
    },
    {
      "id": 345,
      "start": 800.7,
      "end": 802.7,
      "text": " 근처에다"
    },
    {
      "id": 346,
      "start": 802.7,
      "end": 803.7,
      "text": " 이렇게"
    },
    {
      "id": 347,
      "start": 805.7,
      "end": 807.7,
      "text": " 이런 식으로"
    },
    {
      "id": 348,
      "start": 807.7,
      "end": 809.7,
      "text": " 간다는 거죠?"
    },
    {
      "id": 349,
      "start": 811.7,
      "end": 813.7,
      "text": " 그리고"
    },
    {
      "id": 350,
      "start": 813.7,
      "end": 816.7,
      "text": " 뭐 이런 데도 하나 가지고"
    },
    {
      "id": 351,
      "start": 816.7,
      "end": 818.7,
      "text": " 자 이렇게 랜덤하게 좀 뿌려주면은"
    },
    {
      "id": 352,
      "start": 818.7,
      "end": 819.7,
      "text": " 자 저희가"
    },
    {
      "id": 353,
      "start": 819.7,
      "end": 821.7,
      "text": " 이제 도트"
    },
    {
      "id": 354,
      "start": 821.7,
      "end": 822.7,
      "text": " 픽셀 형태로"
    },
    {
      "id": 355,
      "start": 822.7,
      "end": 823.7,
      "text": " 얼룩지게 만든 거잖아요?"
    },
    {
      "id": 356,
      "start": 823.7,
      "end": 824.7,
      "text": " 근데"
    },
    {
      "id": 357,
      "start": 824.7,
      "end": 826.7,
      "text": " 이게 무슨 이미지는 전혀 모르고"
    },
    {
      "id": 358,
      "start": 826.7,
      "end": 828.7,
      "text": " 그냥 전혀 아무도 알 수 없지만"
    },
    {
      "id": 359,
      "start": 828.7,
      "end": 829.7,
      "text": " 그래도 비주얼이"
    },
    {
      "id": 360,
      "start": 829.7,
      "end": 830.7,
      "text": " 힙해진다"
    },
    {
      "id": 361,
      "start": 830.7,
      "end": 831.7,
      "text": " 그렇죠?"
    },
    {
      "id": 362,
      "start": 831.7,
      "end": 832.7,
      "text": " 지금 이걸 통해서"
    },
    {
      "id": 363,
      "start": 832.7,
      "end": 834.7,
      "text": " 확인을 할 수 있을 것 같아요"
    },
    {
      "id": 364,
      "start": 834.7,
      "end": 835.7,
      "text": " 자 이런 것들도"
    },
    {
      "id": 365,
      "start": 835.7,
      "end": 836.7,
      "text": " 이제 적당히 가끔씩"
    },
    {
      "id": 366,
      "start": 836.7,
      "end": 837.7,
      "text": " 넣어주면 될 것 같습니다."
    },
    {
      "id": 367,
      "start": 837.7,
      "end": 838.7,
      "text": " 여기 좀 과하니까"
    },
    {
      "id": 368,
      "start": 838.7,
      "end": 839.7,
      "text": " 그냥 여기 있으면서"
    },
    {
      "id": 369,
      "start": 839.7,
      "end": 840.7,
      "text": " 여기가 조금"
    },
    {
      "id": 370,
      "start": 840.7,
      "end": 842.7,
      "text": " 너무 많아 보이죠?"
    },
    {
      "id": 371,
      "start": 842.7,
      "end": 844.7,
      "text": " 여기 좀 빼줄게요."
    },
    {
      "id": 372,
      "start": 845.7,
      "end": 847.7,
      "text": " 이렇게 해서"
    },
    {
      "id": 373,
      "start": 847.7,
      "end": 848.7,
      "text": " 삭제"
    },
    {
      "id": 374,
      "start": 848.7,
      "end": 849.7,
      "text": " 이 정도면은"
    },
    {
      "id": 375,
      "start": 849.7,
      "end": 850.7,
      "text": " 충분히"
    },
    {
      "id": 376,
      "start": 850.7,
      "end": 851.7,
      "text": " 이제"
    },
    {
      "id": 377,
      "start": 851.7,
      "end": 853.7,
      "text": " 좀 그런게 있죠? 그 뭐라죠?"
    },
    {
      "id": 378,
      "start": 853.7,
      "end": 854.7,
      "text": " 이걸"
    },
    {
      "id": 379,
      "start": 854.7,
      "end": 855.7,
      "text": " 네. balance 감이"
    },
    {
      "id": 380,
      "start": 855.7,
      "end": 856.7,
      "text": " 괜찮게 잡혀 있죠?"
    },
    {
      "id": 381,
      "start": 856.7,
      "end": 858.7,
      "text": " 자 이렇게 디자인을 하시면"
    },
    {
      "id": 382,
      "start": 858.7,
      "end": 859.7,
      "text": " 된다"
    },
    {
      "id": 383,
      "start": 859.7,
      "end": 860.7,
      "text": " 좋습니다"
    },
    {
      "id": 384,
      "start": 860.7,
      "end": 861.7,
      "text": " 이런 예시에"
    },
    {
      "id": 385,
      "start": 861.7,
      "end": 862.7,
      "text": " 조금 더 변형을 해보면"
    },
    {
      "id": 386,
      "start": 862.7,
      "end": 864.7,
      "text": " 를 한 번 또 살펴볼게요"
    }
  ],
