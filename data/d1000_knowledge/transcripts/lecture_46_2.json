      "id": 106,
      "start": 298.32000000000005,
      "end": 300.92,
      "text": " 발휘해 보도록 하겠습니다."
    },
    {
      "id": 107,
      "start": 300.92,
      "end": 303.72,
      "text": " 네. minus 20. 해주고 한 20 해주고"
