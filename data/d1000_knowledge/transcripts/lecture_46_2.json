      "start": 395.16,
      "end": 399.48,
      "text": " 카피라이팅 하는 것도 잘 보시면 될 건데요."
    },
    {
      "id": 149,
      "start": 399.48,
      "end": 402.44,
      "text": " 바라본다는 거 세대해"
    },
    {
      "id": 150,
      "start": 402.44,
      "end": 405.64,
      "text": " 우리는 바라본은"
    },
    {
      "id": 151,
      "start": 405.64,
      "end": 408.56,
      "text": " 바라본다는 행위에 무기를"
    },
    {
      "id": 152,
      "start": 408.56,
      "end": 413.28000000000003,
      "text": " 우리는 너무 작게 생각하고는 한다."
    },
    {
      "id": 153,
      "start": 413.28,
      "end": 416.35999999999996,
      "text": " 하지만 두 인간"
    },
    {
      "id": 154,
      "start": 416.35999999999996,
      "end": 419.35999999999996,
      "text": " 두"
    },
    {
      "id": 155,
      "start": 419.35999999999996,
      "end": 421.35999999999996,
      "text": " 눈을 서로"
    },
    {
      "id": 156,
      "start": 421.35999999999996,
      "end": 424.64,
      "text": " 맞대고 있다는"
    },
    {
      "id": 157,
      "start": 424.64,
      "end": 427.91999999999996,
      "text": " 특히나 얼굴에 조형적"
    },
    {
      "id": 158,
      "start": 427.91999999999996,
      "end": 430.35999999999996,
      "text": " 핵심부를"
    },
    {
      "id": 159,
      "start": 430.35999999999996,
      "end": 433.96,
      "text": " 무해 서로 집중을 하면서"
    },
    {
      "id": 160,
      "start": 433.96,
      "end": 436.55999999999995,
      "text": " 이 막강한 조형적"
    },
    {
      "id": 161,
      "start": 436.55999999999995,
      "end": 441.2,
      "text": " 흐빈력의 지하여"
    },
    {
      "id": 162,
      "start": 441.2,
      "end": 443.68,
      "text": " 주위에"
    },
    {
      "id": 163,
      "start": 443.68,
      "end": 447.15999999999997,
      "text": " 모든"
    },
    {
      "id": 164,
      "start": 447.15999999999997,
      "end": 449.47999999999996,
      "text": " 모든 것들을"
    },
    {
      "id": 165,
      "start": 449.47999999999996,
      "end": 452.76,
      "text": " 입고 오로시"
    },
    {
      "id": 166,
      "start": 452.76,
      "end": 455.52,
      "text": " 또 눈 속에"
    },
    {
      "id": 167,
      "start": 455.52,
      "end": 457.88,
      "text": " 무슨"
    },
    {
      "id": 168,
      "start": 457.88,
      "end": 461.2,
      "text": " 무늬가 있는지"
    },
    {
      "id": 169,
      "start": 461.2,
      "end": 462.71999999999997,
      "text": " 궁금해"
    },
    {
      "id": 170,
      "start": 462.71999999999997,
      "end": 463.76,
      "text": " 하는"
    },
    {
      "id": 171,
      "start": 463.76,
      "end": 465.84,
      "text": " 몇 초간에 정적"
    },
    {
      "id": 172,
      "start": 465.84,
      "end": 469.48,
      "text": " 이런 식으로 완전히 또 개소리 쓰고 있습니다."
    },
    {
      "id": 173,
      "start": 469.48,
      "end": 470.84,
      "text": " 이런 것들을"
    },
    {
      "id": 174,
      "start": 470.84,
      "end": 473.52,
      "text": " 우리는 어떻게"
    },
    {
      "id": 175,
      "start": 473.52,
      "end": 475.52,
      "text": " 단순히"
    },
    {
      "id": 176,
      "start": 475.52,
      "end": 481.15999999999997,
      "text": " 자 어떻게 단순히"
    },
    {
      "id": 177,
      "start": 481.15999999999997,
      "end": 483.64,
      "text": " 하나의 사회적"
    },
    {
      "id": 178,
      "start": 483.64,
      "end": 485.91999999999996,
      "text": " 예의"
    },
    {
      "id": 179,
      "start": 485.91999999999996,
      "end": 488.67999999999995,
      "text": " 가려 우리는 말을 할 때"
    },
    {
      "id": 180,
      "start": 488.67999999999995,
      "end": 490.64,
      "text": " 두 눈을"
    },
    {
      "id": 181,
      "start": 490.64,
      "end": 492.32,
      "text": " 와주치라고도"
    },
    {
      "id": 182,
      "start": 492.32,
      "end": 495.35999999999996,
      "text": " 배웠으니"
    },
    {
      "id": 183,
      "start": 495.35999999999996,
      "end": 497.88,
      "text": " 혹은 어떤 사랑에"
    },
    {
      "id": 184,
      "start": 497.88,
      "end": 501.52,
      "text": " 아주 부가적인"
    },
    {
      "id": 185,
      "start": 501.52,
      "end": 502.92,
      "text": " 행"
    },
    {
      "id": 186,
      "start": 502.92,
      "end": 504.44,
      "text": " 증표"
    },
    {
      "id": 187,
      "start": 504.44,
      "end": 506.96,
      "text": " 증표 정도로"
    },
    {
      "id": 188,
      "start": 506.96,
      "end": 510.64,
      "text": " 생각을 하고 있는"
    },
    {
      "id": 189,
      "start": 510.64,
      "end": 512.96,
      "text": " 것인가"
    },
    {
      "id": 190,
      "start": 512.96,
      "end": 514.88,
      "text": " 우리는 이에 대해서"
    },
    {
      "id": 191,
      "start": 514.88,
      "end": 516.12,
      "text": " 조금 더"
    },
    {
      "id": 192,
      "start": 516.12,
      "end": 518.88,
      "text": " 다양하고 깊게"
    },
    {
      "id": 193,
      "start": 518.88,
      "end": 521.0,
      "text": " 하고 깊게"
    },
    {
      "id": 194,
      "start": 521.0,
      "end": 525.2,
      "text": " 탕구해보아야"
    },
    {
      "id": 195,
      "start": 525.2,
      "end": 527.2,
      "text": " 할"
    },
    {
      "id": 196,
      "start": 527.88,
      "end": 530.48,
      "text": " 필요가 있다"
    },
    {
      "id": 197,
      "start": 530.48,
      "end": 532.36,
      "text": " 외과학적인"
    },
    {
      "id": 198,
      "start": 532.36,
      "end": 536.68,
      "text": " 메커니즘부터 시작"
    },
    {
      "id": 199,
      "start": 536.68,
      "end": 539.72,
      "text": " 해서 동소 부금을"
    },
    {
      "id": 200,
      "start": 539.72,
      "end": 541.68,
      "text": " 꽤 뚫는"
    },
    {
      "id": 201,
      "start": 541.68,
      "end": 543.48,
      "text": " 신화적인"
    },
    {
      "id": 202,
      "start": 543.48,
      "end": 544.76,
      "text": " 상징"
    },
    {
      "id": 203,
      "start": 544.76,
      "end": 548.28,
      "text": " 그리고 일을 넘어"
    },
    {
      "id": 204,
      "start": 548.28,
      "end": 549.76,
      "text": " 넘어서"
    },
    {
      "id": 205,
      "start": 549.76,
      "end": 552.84,
      "text": " 사회과학적인"
    },
    {
      "id": 206,
      "start": 552.84,
      "end": 555.16,
      "text": " 역할까지"
    },
    {
      "id": 207,
      "start": 555.16,
      "end": 555.88,
      "text": " 모두"
    },
    {
      "id": 208,
      "start": 555.88,
      "end": 557.32,
      "text": " 분석을"
    },
    {
      "id": 209,
      "start": 557.32,
      "end": 558.32,
      "text": " 해볼"
    },
    {
      "id": 210,
      "start": 558.32,
      "end": 559.92,
      "text": " 필요가"
    },
    {
      "id": 211,
      "start": 559.92,
      "end": 560.72,
      "text": " 있다"
    },
    {
      "id": 212,
      "start": 560.72,
      "end": 562.56,
      "text": " 아주 긁게 써봤어요"
    },
    {
      "id": 213,
      "start": 562.56,
      "end": 564.0,
      "text": " 너무 긴데"
    },
    {
      "id": 214,
      "start": 564.0,
      "end": 565.2,
      "text": " 어려웠어요"
    },
    {
      "id": 215,
      "start": 565.2,
      "end": 568.28,
      "text": " 아무내용 없는 걸 쓰느라"
    },
    {
      "id": 216,
      "start": 568.28,
      "end": 569.64,
      "text": " 행간이 느려주고"
    },
    {
      "id": 217,
      "start": 569.64,
      "end": 570.88,
      "text": " 뛰었을게"
    },
    {
      "id": 218,
      "start": 570.88,
      "end": 574.32,
      "text": " 잘 쳐내주고"
    },
    {
      "id": 219,
      "start": 574.32,
      "end": 575.68,
      "text": " 자 이렇게"
    },
    {
      "id": 220,
      "start": 575.68,
      "end": 577.2,
      "text": " 넣어주기만 해도"
    },
    {
      "id": 221,
      "start": 577.2,
      "end": 577.96,
      "text": " 자 이거를"
    },
    {
      "id": 222,
      "start": 577.96,
      "end": 580.16,
      "text": " 찢어주기 레이아웃으로"
    },
    {
      "id": 223,
      "start": 580.16,
      "end": 581.16,
      "text": " 써볼게요"
    },
    {
      "id": 224,
      "start": 581.16,
      "end": 582.6,
      "text": " 자 그리고 살짝 겹치게"
    },
    {
      "id": 225,
      "start": 582.6,
      "end": 584.24,
      "text": " 하는 게 또 핵심이겠죠"
    },
    {
      "id": 226,
      "start": 584.24,
      "end": 586.6800000000001,
      "text": " 그리고 볼 등 좀 두꺼우니까"
    },
    {
      "id": 227,
      "start": 586.6800000000001,
      "end": 588.04,
      "text": " 세미 볼드 정도"
    },
    {
      "id": 228,
      "start": 588.04,
      "end": 589.64,
      "text": " 넣어주고"
    },
    {
      "id": 229,
      "start": 589.64,
      "end": 592.4,
      "text": " 중앙정렬 잘 해주고요"
    },
    {
      "id": 230,
      "start": 592.4,
      "end": 594.52,
      "text": " 여런데도 약간 뭐가 남잖아요"
    },
    {
      "id": 231,
      "start": 594.52,
      "end": 597.08,
      "text": " 자 그런데도 간단한 내용들을"
    },
    {
      "id": 232,
      "start": 597.08,
      "end": 600.72,
      "text": " 써줄 수 있겠죠"
    },
    {
      "id": 233,
      "start": 600.72,
      "end": 602.72,
      "text": " 잠깐"
    },
    {
      "id": 234,
      "start": 602.72,
      "end": 603.96,
      "text": " 뭐 이 창상 작가가 나오는 게"
    },
    {
      "id": 235,
      "start": 603.96,
      "end": 605.12,
      "text": " 좀 긴인데"
    },
    {
      "id": 236,
      "start": 605.12,
      "end": 605.84,
      "text": " 아무튼"
    },
    {
      "id": 237,
      "start": 605.84,
      "end": 608.44,
      "text": " 어느 텍스트가 될 수 있는 거고요"
    },
    {
      "id": 238,
      "start": 608.44,
      "end": 609.76,
      "text": " 자 이런 식으로 여기 정도의"
    },
    {
      "id": 239,
      "start": 609.76,
      "end": 611.24,
      "text": " 하나"
    },
    {
      "id": 240,
      "start": 611.24,
      "end": 612.64,
      "text": " 들어가주고"
    },
    {
      "id": 241,
      "start": 612.68,
      "end": 614.52,
      "text": " 자 여기도 좀 비어 있죠"
    },
    {
      "id": 242,
      "start": 614.52,
      "end": 615.3199999999999,
      "text": " 자 이런데는"
    },
    {
      "id": 243,
      "start": 615.3199999999999,
      "end": 617.0,
      "text": " 저게 했던 이런 것들"
    },
    {
      "id": 244,
      "start": 617.0,
      "end": 618.92,
      "text": " 이런 것들이 깔끔하게"
    },
    {
      "id": 245,
      "start": 618.92,
      "end": 620.28,
      "text": " 들어오기만 해도"
    },
    {
      "id": 246,
      "start": 620.28,
      "end": 622.64,
      "text": " 작끝나는 디자인이다"
    },
    {
      "id": 247,
      "start": 622.64,
      "end": 625.3199999999999,
      "text": " 살짝 사이즈를 좀 키워주고요"
    },
    {
      "id": 248,
      "start": 625.3199999999999,
      "end": 626.68,
      "text": " 자 이렇게"
    },
    {
      "id": 249,
      "start": 626.68,
      "end": 627.76,
      "text": " 색상은"
    },
    {
      "id": 250,
      "start": 627.76,
      "end": 630.4,
      "text": " 자 이 레드로 통일"
    },
    {
      "id": 251,
      "start": 630.4,
      "end": 632.1999999999999,
      "text": " 좋습니다"
    },
    {
      "id": 252,
      "start": 632.1999999999999,
      "end": 633.96,
      "text": " 머리바라 보다"
    },
    {
      "id": 253,
      "start": 633.96,
      "end": 635.96,
      "text": " 채워우면"
    },
    {
      "id": 254,
      "start": 635.96,
      "end": 638.96,
      "text": " 전시회"
    },
    {
      "id": 255,
      "start": 638.96,
      "end": 641.24,
      "text": " 자 근데 이제 카페라이팅을 저희가 되게"
    },
    {
      "id": 256,
      "start": 641.24,
      "end": 643.5600000000001,
      "text": " 현학적으로 하는 걸 연습해봤는데"
    },
    {
      "id": 257,
      "start": 643.5600000000001,
      "end": 645.24,
      "text": " 이게 좋은 건 절대 아닙니다"
    },
    {
      "id": 258,
      "start": 645.24,
      "end": 648.2,
      "text": " 절대 이게 고급의 것은 절대 아니고"
    },
    {
      "id": 259,
      "start": 648.2,
      "end": 650.16,
      "text": " 다만 이제"
    },
    {
      "id": 260,
      "start": 650.16,
      "end": 652.16,
      "text": " 이런 상업적인 것에서 활용하기에"
    },
    {
      "id": 261,
      "start": 652.16,
      "end": 653.6800000000001,
      "text": " 좋다 라고 생각하시면 될 것 같아요"
    },
    {
      "id": 262,
      "start": 653.6800000000001,
      "end": 655.6800000000001,
      "text": " 우리가 생각한 걸 되게 반대죠"
    },
    {
      "id": 263,
      "start": 655.6800000000001,
      "end": 656.72,
      "text": " 원래는 이제"
    },
    {
      "id": 264,
      "start": 656.72,
      "end": 658.88,
      "text": " 쉬운 말이 상업적이고"
    },
    {
      "id": 265,
      "start": 658.88,
      "end": 661.48,
      "text": " 현학적인 말이 뭔가 교양의 상징이었는데"
    },
    {
      "id": 266,
      "start": 661.48,
      "end": 662.28,
      "text": " 그건 옛날 얘기고"
    },
    {
      "id": 267,
      "start": 662.28,
      "end": 663.12,
      "text": " 요즘은"
    },
    {
      "id": 268,
      "start": 663.12,
      "end": 664.84,
      "text": " 이제 현학적인 말이"
    },
    {
      "id": 269,
      "start": 664.84,
      "end": 667.5600000000001,
      "text": " 완전 상업적인 추게 들어가고요"
    },
    {
      "id": 270,
      "start": 667.5600000000001,
      "end": 669.04,
      "text": " 되게 간결한 말일수록"
    },
    {
      "id": 271,
      "start": 669.04,
      "end": 670.96,
      "text": " 이제는 오히려 고급의 영역이 들어가기 때문에"
    },
    {
      "id": 272,
      "start": 671.0,
      "end": 672.1600000000001,
      "text": " 그런 걸 좀 인지하면서"
    },
    {
      "id": 273,
      "start": 672.1600000000001,
      "end": 673.6800000000001,
      "text": " 카페라이팅 하시면 될 것 같아요"
    },
    {
      "id": 274,
      "start": 673.6800000000001,
      "end": 675.64,
      "text": " 재명전시의"
    },
    {
      "id": 275,
      "start": 675.64,
      "end": 678.64,
      "text": " 글로리쿤"
    },
    {
      "id": 276,
      "start": 678.64,
      "end": 681.4000000000001,
      "text": " 쿤이랑 글로리가 있다고 칩시다"
    },
    {
      "id": 277,
      "start": 681.4000000000001,
      "end": 681.64,
      "text": " 좋습니다"
    },
    {
      "id": 278,
      "start": 688.0400000000001,
      "end": 689.6800000000001,
      "text": " 자 이렇게 배치를 해주면"
    },
    {
      "id": 279,
      "start": 689.6800000000001,
      "end": 690.9200000000001,
      "text": " 괜찮죠?"
    },
    {
      "id": 280,
      "start": 690.9200000000001,
      "end": 692.0400000000001,
      "text": " 좋습니다 여기 살짝"
    },
    {
      "id": 281,
      "start": 692.0400000000001,
      "end": 694.5600000000001,
      "text": " 이제 행간을 좀 줄여주고요"
    },
    {
      "id": 282,
      "start": 694.5600000000001,
      "end": 695.6800000000001,
      "text": " 왜냐하면"
    },
    {
      "id": 283,
      "start": 695.6800000000001,
      "end": 696.32,
      "text": " 줄여주고"
    },
    {
      "id": 284,
      "start": 696.32,
      "end": 699.52,
      "text": " 글씨치 두께 좀 빼줄게요"
    },
    {
      "id": 285,
