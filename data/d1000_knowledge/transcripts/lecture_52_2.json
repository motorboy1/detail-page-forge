    {
      "id": 252,
      "start": 614.0,
      "end": 616.0,
      "text": " 아무튼"
    },
    {
      "id": 253,
      "start": 616.0,
      "end": 618.0,
      "text": " 자, 좋습니다. 이렇게 하면은"
    },
    {
      "id": 254,
      "start": 618.0,
      "end": 619.0,
      "text": " 굉장히 그럴 수 있는 포스터가"
    },
    {
      "id": 255,
      "start": 619.0,
      "end": 620.0,
      "text": " 완성이 됐어요."
