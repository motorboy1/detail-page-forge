    {
      "id": 247,
      "start": 604.0,
      "end": 606.0,
      "text": " 독특한 거를 추구하자마니"
    },
    {
      "id": 248,
      "start": 606.0,
      "end": 608.0,
      "text": " 근데 그게 왜 그런지는 모르겠어요."
    },
    {
      "id": 249,
      "start": 608.0,
      "end": 611.0,
      "text": " 전 세계적으로 그렇게 독특한 거를 추가"
