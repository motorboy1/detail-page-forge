    {
      "id": 236,
      "start": 579.0,
      "end": 581.0,
      "text": " 끝내기 좀 아쉬우니까"
    },
    {
      "id": 237,
      "start": 581.0,
      "end": 583.0,
      "text": " 조금씩만"
