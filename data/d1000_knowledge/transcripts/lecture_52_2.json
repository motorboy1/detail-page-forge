    {
      "id": 240,
      "start": 589.0,
      "end": 591.0,
      "text": " 들어가고"
    },
    {
      "id": 241,
      "start": 591.0,
      "end": 594.0,
      "text": " 자, mpr"
    },
    {
      "id": 242,
      "start": 594.0,
      "end": 596.0,
      "text": " 점, kr"
    },
    {
      "id": 243,
      "start": 596.0,
      "end": 599.0,
      "text": " 를 방문하세요."
