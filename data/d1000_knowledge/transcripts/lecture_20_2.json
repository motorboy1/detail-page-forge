    {
      "id": 19,
      "start": 48.08,
      "end": 49.92,
      "text": " 여기 사람들 중에서"
    },
    {
      "id": 20,
      "start": 49.92,
      "end": 53.16,
      "text": " 약간 친구할 수 있을 것 같은 사람을 쓰면 안 돼요"
    },
    {
      "id": 21,
      "start": 53.16,
      "end": 55.08,
      "text": " 원래 모델은 약간"
    },
    {
      "id": 22,
      "start": 55.16,
      "end": 58.879999999999995,
      "text": " 마음에 안 들게 생겨야지 좋은 모델이거든요"
    },
    {
      "id": 23,
      "start": 58.879999999999995,
      "end": 62.48,
      "text": " 보시면 자 보세요"
    },
    {
      "id": 24,
      "start": 62.48,
      "end": 64.52,
      "text": " 이제 봤을 때"
    },
    {
      "id": 25,
      "start": 64.52,
      "end": 66.67999999999999,
      "text": " 이 사람 너무 친구할 수 있을 것 같잖아요"
    },
    {
      "id": 26,
      "start": 66.67999999999999,
      "end": 67.88,
      "text": " 친구 같죠"
    },
    {
      "id": 27,
      "start": 67.88,
      "end": 70.32,
      "text": " 이 사람도 되게 칠해 보이죠 사람이"
    },
    {
      "id": 28,
      "start": 70.32,
      "end": 73.56,
      "text": " 이 사람도 좀 까칠해 보이지만 칠해 보이고"
    },
    {
      "id": 29,
      "start": 73.56,
      "end": 75.6,
      "text": " 근데 이제 보다 보면 약간"
    },
    {
      "id": 30,
      "start": 75.6,
      "end": 78.92,
      "text": " 아 이 아주시랑은 친구가 약간 좀 박스인데"
    },
    {
      "id": 31,
      "start": 78.92,
      "end": 80.8,
      "text": " 싶은 사람들 있어요"
    },
    {
      "id": 32,
      "start": 80.92,
      "end": 86.28,
      "text": " 그런 사람들 사진을 써주시면 되는 거고"
    },
    {
      "id": 33,
      "start": 86.28,
      "end": 88.39999999999999,
      "text": " 이래 사람 너무 약간 친근하잖아요"
    },
    {
      "id": 34,
      "start": 88.39999999999999,
      "end": 90.0,
      "text": " 그렇죠? 친근하지 않아요 너무"
    },
    {
      "id": 35,
      "start": 90.0,
      "end": 92.92,
      "text": " 좀 이 사람 좀 안 친근하죠"
    },
    {
      "id": 36,
      "start": 92.92,
      "end": 95.36,
      "text": " 이런 것들을 쓰면 되는 건데"
    },
    {
      "id": 37,
      "start": 95.36,
      "end": 97.47999999999999,
      "text": " 이 아시도 조금 안 친근한 것 같아요"
    },
    {
      "id": 38,
      "start": 97.47999999999999,
      "end": 98.84,
      "text": " 제가 느끼기엔"
    },
    {
      "id": 39,
      "start": 98.84,
      "end": 100.75999999999999,
      "text": " 그런 류으로 잘 골라 봤고"
    },
    {
      "id": 40,
      "start": 100.75999999999999,
      "end": 102.72,
      "text": " 넣어주시면 되고"
    },
    {
      "id": 41,
      "start": 102.72,
      "end": 107.84,
      "text": " 저는 어떤 사진을 넣을지 한번 촉촉 보다가"
    },
    {
      "id": 42,
      "start": 107.84,
      "end": 111.24000000000001,
      "text": " 아 이 사람 성격도 나빠 보이고"
    },
    {
      "id": 43,
      "start": 111.24000000000001,
      "end": 113.68,
      "text": " 네 성격이 나빠 나빠 보여 무서워요"
    },
    {
      "id": 44,
      "start": 113.68,
      "end": 114.44,
      "text": " 그렇죠?"
    },
    {
      "id": 45,
      "start": 114.44,
      "end": 115.60000000000001,
      "text": " 무서움을 좋은 겁니다"
    },
    {
      "id": 46,
      "start": 115.60000000000001,
      "end": 117.44,
      "text": " 모델은 원래 무서워야 돼요"
    },
    {
      "id": 47,
      "start": 117.44,
      "end": 119.92,
      "text": " 이 사람을 넣을 건데 흡백을 한번 넣어 볼게요"
    },
    {
      "id": 48,
      "start": 119.92,
      "end": 121.76,
      "text": " 자 이거 흡백 넣을 때"
    },
    {
      "id": 49,
      "start": 121.76,
      "end": 124.68,
      "text": " 살짝 날려주고 컨트롤을 올려주고"
    },
    {
      "id": 50,
      "start": 124.68,
      "end": 126.52000000000001,
      "text": " 섀도 지나게 넣어주고 이렇게"
    },
    {
      "id": 51,
      "start": 126.52000000000001,
      "end": 129.92000000000002,
      "text": " 이렇게 해야지 약간 필름 느낌 나면서 좋다고 했었죠"
    },
    {
      "id": 52,
      "start": 129.92000000000002,
      "end": 131.64000000000001,
      "text": " 자 근데 이제 흡백을 넣을 거니까"
    },
    {
      "id": 53,
      "start": 131.64000000000001,
      "end": 133.72,
      "text": " 세트위션 영풀로 넣어주고"
    },
    {
      "id": 54,
      "start": 134.72,
      "end": 136.92,
      "text": " 약간 이런 식으로 해주세요"
    },
    {
      "id": 55,
      "start": 136.92,
      "end": 140.4,
      "text": " 자 이렇게 반갈 죽을 했어요"
    },
    {
      "id": 56,
      "start": 140.4,
      "end": 142.68,
      "text": " 자 위에도 검정으로 넣어 볼까요 한번"
    },
    {
      "id": 57,
      "start": 142.68,
      "end": 144.68,
      "text": " 자 이렇게 반갈 죽을 했고 이제"
    },
    {
      "id": 58,
      "start": 144.68,
      "end": 153.68,
      "text": " 자 중요한 거는 여기에 다 텍스트를 써주는 거죠"
    },
    {
      "id": 59,
      "start": 153.68,
      "end": 158.68,
      "text": " 친근하다면"
    },
    {
      "id": 60,
      "start": 158.68,
      "end": 160.96,
      "text": " 달라"
    },
    {
      "id": 61,
      "start": 160.96,
      "end": 163.0,
      "text": " 자 그 한 마리를 한번 텍스토로 써 봤어요"
    },
    {
      "id": 62,
      "start": 163.08,
      "end": 166.44,
      "text": " 자 이런 식으로 이제 요소들이 다 여기에 몰려서 들어간다고요"
    },
    {
      "id": 63,
      "start": 166.44,
      "end": 168.12,
      "text": " 자 몰렸어 들어가야 되는데"
    },
    {
      "id": 64,
      "start": 168.12,
      "end": 169.48,
      "text": " 약간 문제가 있어요 지금"
    },
    {
      "id": 65,
      "start": 169.48,
      "end": 172.28,
      "text": " 자 이 사람 눈이 서양이니니시기 때문에"
    },
    {
      "id": 66,
      "start": 172.28,
      "end": 175.92,
      "text": " 굉장히 눈의 조형성이 강해요 그렇죠"
    },
    {
      "id": 67,
      "start": 175.92,
      "end": 177.0,
      "text": " 동양이니를 좀 다르게"
    },
    {
      "id": 68,
      "start": 177.0,
      "end": 180.32,
      "text": " 눈에 뭔가 시선이 굉장히 많이 가는 측면이 있는데"
    },
    {
      "id": 69,
      "start": 180.32,
      "end": 182.24,
      "text": " 자 그렇기 때문에 여기에 텍스트를 써도"
    },
    {
      "id": 70,
      "start": 182.24,
      "end": 185.64,
      "text": " 이 눈에 스시션을 꽂혀 버린다는 단점이 있어요"
    },
    {
      "id": 71,
      "start": 185.64,
      "end": 188.24,
      "text": " 자 그래서 이 사람 눈을 잘라버릴 겁니다"
    },
    {
      "id": 72,
      "start": 188.24,
      "end": 190.24,
      "text": " 눈을 달려버릴 거예요"
    },
    {
      "id": 73,
      "start": 191.24,
      "end": 194.24,
      "text": " 자 이 사람 눈을 이렇게 좀 쭉 당겨서"
    },
    {
      "id": 74,
      "start": 197.24,
      "end": 200.24,
      "text": " 이렇게 날려버릴 겁니다"
    },
    {
      "id": 75,
      "start": 200.24,
      "end": 204.24,
      "text": " 그냥 이렇게 네 입술 부분만 나오게"
    },
    {
      "id": 76,
      "start": 204.24,
      "end": 206.24,
      "text": " 처리를 해볼 건데"
    },
    {
      "id": 77,
      "start": 206.24,
      "end": 208.24,
      "text": " 좋아요"
    },
    {
      "id": 78,
      "start": 208.24,
      "end": 210.24,
      "text": " 자 이렇게 해주고"
    },
    {
      "id": 79,
      "start": 210.24,
      "end": 213.24,
      "text": " 약간 비율도 살짝 조금 이상하게 하면"
    },
    {
      "id": 80,
      "start": 213.24,
      "end": 215.24,
      "text": " 넣어보면 재밌을 것 같긴 하거든요"
    },
    {
      "id": 81,
      "start": 215.24,
      "end": 217.24,
      "text": " 그게 어떻게 넣어버릴 거예요"
    },
    {
      "id": 82,
      "start": 217.24,
      "end": 219.24,
      "text": " 이렇게 이렇게 돌려볼까요"
    },
    {
      "id": 83,
      "start": 224.24,
      "end": 227.24,
      "text": " 자 이런 식으로 넣다가"
    },
    {
      "id": 84,
      "start": 227.24,
      "end": 230.24,
      "text": " 여기를 이렇게 당겨주고 싶은데"
    },
    {
      "id": 85,
      "start": 230.24,
      "end": 234.24,
      "text": " 지금 이게 뭔가 등기로 당겨지고 있어요"
    },
    {
      "id": 86,
      "start": 234.24,
      "end": 236.24,
      "text": " 자 그래서 그거는 좀 별로인데"
    },
    {
      "id": 87,
      "start": 236.24,
      "end": 239.24,
      "text": " 어"
    },
    {
      "id": 88,
      "start": 239.24,
      "end": 241.24,
      "text": " 자 이제 이거 좀 더 넣어버릴게요"
    },
    {
      "id": 89,
      "start": 241.24,
      "end": 243.24,
      "text": " 자 이제 이거 좀 더 넣어버릴게요"
    },
    {
      "id": 90,
      "start": 243.24,
      "end": 250.24,
      "text": " 여기서"
    },
    {
      "id": 91,
      "start": 250.24,
      "end": 254.24,
      "text": " 어 이거 뻔해 아닌 것 같고요"
    },
    {
      "id": 92,
      "start": 256.24,
      "end": 260.24,
      "text": " 자 그러면은 방법을 이렇게 당긴 다음에"
    },
    {
      "id": 93,
      "start": 260.24,
      "end": 263.24,
      "text": " 얘를 이렇게 당기는 느낌으로 해볼게요"
    },
    {
      "id": 94,
      "start": 263.24,
      "end": 266.24,
      "text": " 자 이렇게 해주고"
    },
    {
      "id": 95,
      "start": 266.24,
      "end": 268.24,
      "text": " 이 정도로 저는 잘라버릴게요"
    },
    {
      "id": 96,
      "start": 268.24,
      "end": 270.24,
      "text": " 약간 약간 이상하죠"
    },
    {
      "id": 97,
      "start": 270.24,
      "end": 273.24,
      "text": " 원래 디자인은 좀 이상할수록 좋은 거죠"
    },
    {
      "id": 98,
      "start": 273.24,
      "end": 277.24,
      "text": " 자 그래서 이렇게 약간 뭔가 이상한 느낌으로"
    },
    {
      "id": 99,
      "start": 277.24,
      "end": 280.24,
      "text": " 잘라주고"
    },
    {
      "id": 100,
      "start": 280.24,
      "end": 282.24,
      "text": " 약간 블렌딩 모드도 좀 건드려볼 건데"
    },
    {
      "id": 101,
      "start": 282.24,
      "end": 286.24,
      "text": " 요게 요쪽은 전문 디자이너에도 잘 모르는 부분이에요"
    },
    {
      "id": 102,
      "start": 286.24,
      "end": 288.24,
      "text": " 근데 뭘 하면 되냐면 이렇게 이렇게 해보면서"
    },
    {
      "id": 103,
      "start": 288.24,
      "end": 292.24,
      "text": " 뭔가 재밌어 보이는 효과가 있으면 멈추면 돼요"
    },
    {
      "id": 104,
      "start": 295.24,
      "end": 298.24,
      "text": " 자 이거 지금 검정색이 들어갔기 때문에"
    },
    {
      "id": 105,
      "start": 298.24,
      "end": 300.24,
      "text": " 빼주고 아래"
    },
    {
      "id": 106,
      "start": 300.24,
      "end": 303.24,
      "text": " 이런 식으로 약간 미묘하게 다르거든요"
    },
    {
      "id": 107,
      "start": 303.24,
      "end": 304.24,
      "text": " 그러면은"
    },
    {
      "id": 108,
      "start": 304.24,
      "end": 307.24,
      "text": " 특히 여기가 많이 화이트잖아요 배경은"
    },
    {
      "id": 109,
      "start": 307.24,
      "end": 310.24,
      "text": " 그러면은 얘를 이렇게 했을 때"
    },
    {
      "id": 110,
      "start": 310.24,
      "end": 311.24,
      "text": " 음"
    },
    {
      "id": 111,
      "start": 311.24,
      "end": 314.24,
      "text": " 잠시만요 화이트하고 빨간색 넣어볼게요"
    },
    {
      "id": 112,
      "start": 314.24,
      "end": 317.24,
      "text": " 빨간색으로 넣고 얘를 이렇게 돌려보면"
    },
    {
      "id": 113,
      "start": 317.24,
      "end": 320.24,
      "text": " 다양한 약간 필터가 적용이 되는 거예요"
    },
    {
      "id": 114,
      "start": 320.24,
      "end": 322.24,
      "text": " 자 여기 중에서 뭐 예를 들어서"
    },
    {
      "id": 115,
      "start": 322.24,
      "end": 325.24,
      "text": " 이런 거 원하시면은 이렇게 멈추시면 되는데"
    },
    {
      "id": 116,
      "start": 325.24,
      "end": 328.24,
      "text": " 저가 저도 그렇고 대부분 디자이너 들은 이게 뭐"
    },
    {
      "id": 117,
      "start": 328.24,
      "end": 331.24,
      "text": " 이게 뭐 원리가 뭔지 사실 잘 모르기 때문에"
    },
    {
      "id": 118,
      "start": 331.24,
      "end": 335.24,
      "text": " 야 뭐 이런 거 이런 거 좀 뭔가 강해 보이죠"
    },
    {
      "id": 119,
      "start": 335.24,
      "end": 337.24,
      "text": " 파드라이트 그죠"
    },
    {
      "id": 120,
      "start": 337.24,
      "end": 340.24,
      "text": " 약간 저기 막 약간 인디영화"
    },
    {
      "id": 121,
      "start": 340.24,
      "end": 343.24,
      "text": " 인디흑빛 영화 포스터 같은 느낌을 한번 만들어 볼게요"
    },
    {
      "id": 122,
      "start": 343.24,
      "end": 346.24,
      "text": " 친근하다면 달려왔는데"
    },
    {
      "id": 123,
      "start": 346.24,
      "end": 349.24,
      "text": " 이런 거는 약간 폰트를 다양하게 한번 써볼게요"
    },
    {
      "id": 124,
      "start": 349.24,
      "end": 352.24,
      "text": " 자 힙스터스러운 디자인의 특징은"
    },
    {
      "id": 125,
      "start": 352.24,
      "end": 354.24,
      "text": " 약간 좀 난잡하다는 게 특징이고요"
    },
    {
      "id": 126,
      "start": 354.24,
      "end": 356.24,
      "text": " 이런 거 깔끔하잖아요"
    },
    {
      "id": 127,
      "start": 356.24,
      "end": 360.24,
      "text": " 근데 힙스터 디자인은 약간 고론 깔끔하면서 약간 벗어내야 돼요"
    },
    {
      "id": 128,
      "start": 360.24,
      "end": 361.24,
      "text": " 자 이렇게 하고"
    },
    {
      "id": 129,
      "start": 361.24,
      "end": 363.24,
      "text": " 자 여기도"
    },
    {
      "id": 130,
      "start": 363.24,
      "end": 366.24,
      "text": " 자 어떻게 여기서 미친 짓을 하냐면"
    },
    {
      "id": 131,
      "start": 366.24,
      "end": 368.24,
      "text": " 이렇게 땡겨버린 거예요"
    },
    {
      "id": 132,
      "start": 368.24,
      "end": 369.24,
      "text": " 어 그죠"
    },
    {
      "id": 133,
      "start": 369.24,
      "end": 371.24,
      "text": " 뭔 말인지 아시겠죠"
    },
    {
      "id": 134,
      "start": 371.24,
      "end": 373.24,
      "text": " 이렇게 땡겨버리면은 글자가 이상해져요"
    },
    {
      "id": 135,
      "start": 373.24,
      "end": 374.24,
      "text": " 그죠"
    },
    {
      "id": 136,
