    {
      "id": 50,
      "start": 191.0,
      "end": 193.28,
      "text": " 약간 만 더 진하게"
    },
    {
      "id": 51,
      "start": 193.28,
      "end": 196.56,
      "text": " 이 정도까지 가도 될 것 같고"
    },
    {
      "id": 52,
      "start": 196.56,
      "end": 198.64,
      "text": " 지금 이렇게"
    },
    {
      "id": 53,
      "start": 198.64,
      "end": 200.04,
      "text": " 이렇게 보고 가지"
    },
    {
      "id": 54,
      "start": 200.04,
      "end": 203.64,
      "text": " 이 정도는 해야 되겠죠. 이 정도 해도 충분히 금속 느낌이 나는 것 같아요."
    },
    {
      "id": 55,
      "start": 203.64,
      "end": 210.11999999999998,
      "text": " 이제 양가금가금 조금 잘 넣어볼 건데"
