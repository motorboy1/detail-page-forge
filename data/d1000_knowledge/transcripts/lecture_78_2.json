    },
    {
      "id": 361,
      "start": 841.72,
      "end": 843.72,
      "text": " 아라 뷰"
    },
    {
      "id": 362,
      "start": 843.72,
      "end": 848.72,
      "text": " 이 정도는 해도 될 것 같긴 하거든요."
    },
    {
      "id": 363,
      "start": 848.72,
      "end": 852.72,
      "text": " 살짝 빼주고"
    },
    {
      "id": 364,
      "start": 852.72,
      "end": 857.72,
      "text": " 여기를"
    },
    {
      "id": 365,
      "start": 857.72,
      "end": 860.72,
      "text": " 여기를 조금"
    },
    {
      "id": 366,
      "start": 860.72,
      "end": 865.72,
      "text": " 좀 더 바꿔 잘 바꿔오고 싶다 하시면 올려주고"
    },
    {
      "id": 367,
      "start": 865.72,
      "end": 870.72,
      "text": " 내려주고 하면 좀 더 아라 뷨가 잘 보이겠죠?"
    },
    {
      "id": 368,
      "start": 870.72,
      "end": 876.34,
      "text": " 여기도 한 번 더 올려주고"
    },
    {
      "id": 369,
      "start": 876.34,
      "end": 880.84,
      "text": " 이 정도 해주면은"
    },
    {
      "id": 370,
      "start": 880.84,
      "end": 893.08,
      "text": " 군미 변해까지는 보일 수 있을 것 같고"
    },
    {
      "id": 371,
      "start": 893.08,
      "end": 896.28,
      "text": " 이렇게 잘 조절을 해주면은 아라리우도 보이고"
    },
    {
      "id": 372,
      "start": 896.28,
      "end": 900.36,
      "text": " 나머지도 보이는 상태가 되었습니다."
    },
    {
      "id": 373,
      "start": 900.36,
      "end": 904.8000000000001,
      "text": " 이렇게 해주면은 재미있습니다."
    },
    {
      "id": 374,
      "start": 904.8000000000001,
      "end": 908.8000000000001,
      "text": " 나머지 부분의 우소들을 얹어주면은 되는 겁니다."
    },
    {
      "id": 375,
      "start": 908.8000000000001,
      "end": 911.64,
      "text": " 이번 거 조금 따라하는데 시간이 걸렸어요."
    },
    {
      "id": 376,
      "start": 911.64,
      "end": 915.28,
      "text": " 이것저것 미세 조절을 많이 해서"
    },
    {
      "id": 377,
      "start": 915.28,
      "end": 918.2,
      "text": " 나머지 부분에는 항상 익숙했던 것처럼"
    },
    {
      "id": 378,
      "start": 918.2,
      "end": 922.16,
      "text": " 그냥 테스트들 배치해주는 건가?"
    },
    {
      "id": 379,
      "start": 926.4,
      "end": 928.4,
      "text": " 어렵지 않죠?"
    },
    {
      "id": 380,
      "start": 931.26,
      "end": 936.62,
      "text": " 이제 중앙에"
    },
    {
      "id": 381,
      "start": 949.5,
      "end": 952.1800000000001,
      "text": " 그리고"
    },
    {
      "id": 382,
      "start": 960.36,
      "end": 964.36,
      "text": " 이런 식으로 배치되겠죠?"
    },
    {
      "id": 383,
      "start": 964.36,
      "end": 967.36,
      "text": " 있습니다."
    },
    {
      "id": 384,
      "start": 967.36,
      "end": 971.36,
      "text": " 언니에서 발생하는"
    },
    {
      "id": 385,
      "start": 971.36,
      "end": 975.36,
      "text": " 모든 주요 개노리에"
    },
    {
      "id": 386,
      "start": 975.36,
      "end": 981.36,
      "text": " 엘라운벨과 공격법"
    },
    {
      "id": 387,
      "start": 981.36,
      "end": 987.36,
      "text": " 그리고 이들과 연관된"
    },
    {
      "id": 388,
      "start": 987.36,
      "end": 991.36,
      "text": " 모든 위주를"
    },
    {
      "id": 389,
      "start": 991.36,
      "end": 994.36,
      "text": " 총망을 나아요."
    },
    {
      "id": 390,
      "start": 994.36,
      "end": 997.36,
      "text": " 다만은 냈습니다."
    },
    {
      "id": 391,
      "start": 997.36,
      "end": 1001.36,
      "text": " 간단하게 텍스트 추가해 주고"
    },
    {
      "id": 392,
      "start": 1001.36,
      "end": 1005.36,
      "text": " PDF 200 Plus"
    },
    {
      "id": 393,
      "start": 1005.36,
      "end": 1009.36,
      "text": " 조금 큰 것 같아서"
    },
    {
      "id": 394,
      "start": 1009.36,
      "end": 1013.36,
      "text": " 주려주는 것도 괜찮을 것 같아요."
    },
    {
      "id": 395,
      "start": 1017.36,
      "end": 1027.3600000000001,
      "text": " 100% 위혀로도 100%"
    },
    {
      "id": 396,
      "start": 1027.3600000000001,
      "end": 1031.3600000000001,
      "text": " 그리고 이제 남는 부분들은"
    },
    {
      "id": 397,
      "start": 1031.3600000000001,
      "end": 1034.3600000000001,
      "text": " 한 번은 로고 같은 것"
    },
    {
      "id": 398,
      "start": 1034.3600000000001,
      "end": 1037.3600000000001,
      "text": " 새로운 로고는 유친구들을 써볼게요."
    },
    {
      "id": 399,
      "start": 1037.36,
      "end": 1050.36,
      "text": " 이제 연구에"
    },
    {
      "id": 400,
      "start": 1050.36,
      "end": 1052.36,
      "text": " 뭐 이런 거"
    },
    {
      "id": 401,
      "start": 1052.36,
      "end": 1055.36,
      "text": " 전혀 뭔지 모르겠고요."
    },
    {
      "id": 402,
      "start": 1055.36,
      "end": 1059.36,
      "text": " 이런 거 좀 써주고"
    },
    {
      "id": 403,
      "start": 1059.36,
      "end": 1062.36,
      "text": " 이렇게 전반적으로 다 볼드하게 처리해서"
    },
    {
      "id": 404,
      "start": 1062.36,
      "end": 1065.36,
      "text": " 마무리를 해주시면 됩니다."
    },
    {
      "id": 405,
      "start": 1065.36,
      "end": 1068.36,
      "text": " 이렇게 주고"
    },
    {
      "id": 406,
      "start": 1068.36,
      "end": 1072.36,
      "text": " 우리가 60이니까"
    },
    {
      "id": 407,
      "start": 1072.36,
      "end": 1075.36,
      "text": " 또 육식으로 이렇게 맞추고요."
    },
    {
      "id": 408,
      "start": 1089.36,
      "end": 1092.36,
      "text": " 위쪽에 또 간단한 텍스트들만"
    },
    {
      "id": 409,
      "start": 1092.36,
      "end": 1095.36,
      "text": " 맺지게 주면 끝."
    },
    {
      "id": 410,
      "start": 1095.36,
      "end": 1101.36,
      "text": " 40인데 이쪽이 10도가 될 것 같고"
    },
    {
      "id": 411,
      "start": 1101.36,
      "end": 1106.36,
      "text": " 아니면 전반적으로 20씩 다시 돌려놓고"
    },
    {
      "id": 412,
      "start": 1106.36,
      "end": 1109.36,
      "text": " 아래에서도 20 올려주는"
    },
    {
      "id": 413,
      "start": 1109.36,
      "end": 1112.36,
      "text": " 손도 좋습니다."
    },
    {
      "id": 414,
      "start": 1112.36,
      "end": 1117.36,
      "text": " 2025년 반"
    },
    {
      "id": 415,
      "start": 1118.36,
      "end": 1121.36,
      "text": " 이쪽"
    },
    {
      "id": 416,
      "start": 1121.36,
      "end": 1127.36,
      "text": " 2080P"
    },
    {
      "id": 417,
      "start": 1127.36,
      "end": 1129.36,
      "text": " 이렇게만 처리해줘도"
    },
    {
      "id": 418,
      "start": 1129.36,
      "end": 1132.36,
      "text": " 나름 유띠를 잘 활용해가지고"
    },
    {
      "id": 419,
      "start": 1132.36,
      "end": 1134.36,
      "text": " 디자인이 들어갔죠."
    },
    {
      "id": 420,
      "start": 1134.36,
      "end": 1137.36,
      "text": " 조금 더 두껍게 넣어볼까요?"
    },
    {
      "id": 421,
      "start": 1137.36,
      "end": 1140.36,
      "text": " 어떻게 짧을 것 같아요."
    },
    {
      "id": 422,
      "start": 1140.36,
      "end": 1142.36,
      "text": " 위저도"
    },
    {
      "id": 423,
      "start": 1143.36,
      "end": 1147.36,
      "text": " 이 정도로 조각해도 괜찮은 보이기 때문에"
    },
    {
      "id": 424,
      "start": 1147.36,
      "end": 1150.36,
      "text": " 이것만 잘 맞춰주면 되겠죠."
    },
    {
      "id": 425,
      "start": 1156.36,
      "end": 1159.36,
      "text": " 두껍게 넣어도 충분히 괜찮다."
    },
    {
      "id": 426,
      "start": 1159.36,
      "end": 1162.36,
      "text": " 라는 생각이 들고 여기"
    },
    {
      "id": 427,
      "start": 1162.36,
      "end": 1165.36,
      "text": " 그 자만 살짝 이렇게 좀 띄워주고"
    },
    {
      "id": 428,
      "start": 1183.36,
      "end": 1184.36,
      "text": " 좋습니다."
    },
    {
      "id": 429,
      "start": 1184.36,
      "end": 1186.36,
      "text": " 이 정도로 마무리 해보도록 할게요."
    }
