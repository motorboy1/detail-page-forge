    },
    {
      "id": 25,
      "start": 93.44,
      "end": 95.11999999999999,
      "text": " 이렇게"
    },
    {
      "id": 26,
      "start": 97.6,
      "end": 101.52,
      "text": " 자 여기서 이렇게 가지고"
    },
    {
      "id": 27,
      "start": 101.92,
      "end": 105.03999999999999,
      "text": " 이런 것도 튬세에 끼워준다는 느낌."
    },
    {
      "id": 28,
      "start": 105.76,
      "end": 108.24000000000001,
      "text": " 자 아까도 말씀을 드렸지만"
    },
    {
      "id": 29,
      "start": 108.24000000000001,
      "end": 111.04,
      "text": " 여기 배치를 할 때 생각보다 어렵잖아요."
    },
    {
      "id": 30,
      "start": 111.04,
      "end": 115.2,
      "text": " 뭐 어떻게 배치를 해도 안에 다 들어가는 구석이 하나씩 있기 때문에"
    },
    {
      "id": 31,
      "start": 116.24000000000001,
      "end": 120.0,
      "text": " 자 이렇게 그냥 막 만들어도 충분히 다 배치를 할 수가 있다."
    },
    {
      "id": 32,
      "start": 120.64,
      "end": 122.64000000000001,
      "text": " 자 이런 것도"
    },
    {
      "id": 33,
      "start": 122.64000000000001,
      "end": 124.64000000000001,
      "text": " 이렇게"
    },
    {
      "id": 34,
      "start": 125.04,
      "end": 127.36000000000001,
      "text": " 얘는 약간 여정도에서 멈추겠죠."
    },
    {
      "id": 35,
      "start": 127.36000000000001,
      "end": 130.64000000000001,
      "text": " 그렇죠? 틈이 이 여기서 막히니까"
    },
    {
      "id": 36,
      "start": 131.36,
      "end": 133.36,
      "text": " 자 좋습니다."
    },
    {
      "id": 37,
      "start": 135.76,
      "end": 139.76,
      "text": " 자 이런 것도 돌싸듯이"
    },
    {
      "id": 38,
      "start": 140.48,
      "end": 142.48,
      "text": " 근데 여기 약간 이제 계곡에 놀러 가서"
    },
    {
      "id": 39,
      "start": 143.51999999999998,
      "end": 146.72,
      "text": " 거기 있는 돌들 같고 뭔가 이제 땜 같은 거 쌓는"
    },
    {
      "id": 40,
      "start": 147.12,
      "end": 148.64,
      "text": " 그런 느낌이 되는 거죠."
    },
    {
      "id": 41,
      "start": 150.16,
      "end": 152.16,
      "text": " 이런 것도"
    },
    {
      "id": 42,
      "start": 152.56,
      "end": 154.56,
      "text": " 이렇게 기울여서에는"
    },
    {
      "id": 43,
      "start": 155.6,
      "end": 157.6,
      "text": " 여기쯤에 싸울 수 있을 것 같고"
    },
    {
      "id": 44,
      "start": 159.68,
      "end": 161.68,
      "text": " 길쭉한 것도 하나 만들고 올게요."
    },
    {
      "id": 45,
      "start": 162.56,
      "end": 164.48,
      "text": " 길쭉한 돌도 있을 수 있겠죠."
    },
    {
      "id": 46,
      "start": 166.0,
      "end": 168.0,
      "text": " 자 이동 검정색"
    },
    {
      "id": 47,
      "start": 168.48,
      "end": 170.48,
      "text": " 일단 검정색을 다 넣을게요."
    },
    {
      "id": 48,
      "start": 170.48,
      "end": 174.64,
      "text": " 이런 식으로 여기 딱 뭔가 딱 놓일 수 있을 것 같아요."
    },
    {
      "id": 49,
      "start": 174.64,
      "end": 178.48,
      "text": " 제가 보기 살짝 기울여 줄 수도 있을 것 같고"
    },
    {
      "id": 50,
      "start": 179.2,
      "end": 181.2,
      "text": " 그렇죠?"
    },
    {
      "id": 51,
      "start": 182.0,
      "end": 184.0,
      "text": " 이렇게"
    },
    {
      "id": 52,
      "start": 184.0,
      "end": 186.0,
      "text": " 이런 식으로 쌓아줄 수 있을 것 같은데"
    },
    {
      "id": 53,
      "start": 186.0,
      "end": 188.0,
      "text": " 얘는 이제 조금 더 위까지 쌓아 볼게요."
    },
    {
      "id": 54,
      "start": 188.0,
      "end": 190.0,
      "text": " 한 번"
    },
    {
      "id": 55,
      "start": 190.48,
      "end": 192.48,
      "text": " 자 이런 것도"
    },
    {
      "id": 56,
      "start": 193.44,
      "end": 195.44,
      "text": " 돌들이 쭉쭉 쌓인 거죠."
    },
    {
      "id": 57,
      "start": 200.64,
      "end": 202.64,
      "text": " 자 여기 형태를 그냥 랜덤하게"
    },
    {
      "id": 58,
      "start": 202.64,
      "end": 204.64,
      "text": " 많이 많이 쌓아 준다."
    },
    {
      "id": 59,
      "start": 204.64,
      "end": 205.83999999999997,
      "text": " 그런 게"
    },
    {
      "id": 60,
      "start": 205.83999999999997,
      "end": 207.04,
      "text": " 요 조형 핵심인 것 같아요."
    },
    {
      "id": 61,
      "start": 207.04,
      "end": 208.48,
      "text": " 요 틈새들이 다 약간"
    },
    {
      "id": 62,
      "start": 208.48,
      "end": 211.12,
      "text": " 하나의 패턴을 일어내면서"
    },
    {
      "id": 63,
      "start": 211.12,
      "end": 213.44,
      "text": " 전반적으로 재밌는 조형이"
    },
    {
      "id": 64,
      "start": 213.44,
      "end": 215.44,
      "text": " 나올 수밖에 없기 때문에"
    },
    {
      "id": 65,
      "start": 215.44,
      "end": 217.44,
      "text": " 핵심은 그냥 많이 쌓는다."
    },
    {
      "id": 66,
      "start": 219.44,
      "end": 221.44,
      "text": " 그리고 많이 쌓으면서"
    },
    {
      "id": 67,
      "start": 221.52,
      "end": 223.52,
      "text": " 멍청에 대한 랜덤하게 쌓는다."
    },
    {
      "id": 68,
      "start": 223.52,
      "end": 224.52,
      "text": " 요거입니다."
    },
    {
      "id": 69,
      "start": 224.52,
      "end": 226.0,
      "text": " 이런 식으로 가는 거죠."
    },
    {
      "id": 70,
      "start": 226.0,
      "end": 229.04,
      "text": " 그리고 이제 위에다는 잘 텍스트 잘 넣어줄 것 같고"
    },
    {
      "id": 71,
      "start": 229.04,
      "end": 231.12,
      "text": " 자 이제 얘네를 가지고"
    },
    {
      "id": 72,
      "start": 231.12,
      "end": 232.32,
      "text": " 재밌게 꾸며볼게요."
    },
    {
      "id": 73,
      "start": 232.32,
      "end": 234.0,
      "text": " 자 이런 거 하나"
    },
    {
      "id": 74,
      "start": 234.0,
      "end": 235.35999999999999,
      "text": " 좀 더 골라서"
    },
    {
      "id": 75,
      "start": 235.35999999999999,
      "end": 236.8,
      "text": " 자 질감도 넣어줄게요."
    },
    {
      "id": 76,
      "start": 236.8,
      "end": 238.24,
      "text": " 자 락"
    },
    {
      "id": 77,
      "start": 238.24,
      "end": 239.92,
      "text": " 여취면은 뭘게"
    },
    {
      "id": 78,
      "start": 239.92,
      "end": 241.68,
      "text": " 질감들이 나오죠."
    },
    {
      "id": 79,
      "start": 241.68,
      "end": 243.52,
      "text": " 자 이런 걸로 몇 개는 그냥"
    },
    {
      "id": 80,
      "start": 243.52,
      "end": 245.68,
      "text": " 좀 이런 키치한 느낌을 살려서"
    },
    {
      "id": 81,
      "start": 245.68,
      "end": 247.68,
      "text": " 자 돌 질감을 넣어주는 겁니다."
    },
    {
      "id": 82,
      "start": 248.16,
      "end": 249.16,
      "text": " 자"
    },
    {
      "id": 83,
      "start": 250.88,
      "end": 251.76000000000002,
      "text": " 그쵸 이렇게"
    },
    {
      "id": 84,
      "start": 251.76000000000002,
      "end": 253.6,
      "text": " 왜냐하면 이게 진짜 돌같이 다 안 쳐."
    },
    {
      "id": 85,
      "start": 253.6,
      "end": 255.36,
      "text": " 근데 오히려 디자인 쪽"
    },
    {
      "id": 86,
      "start": 255.36,
      "end": 257.6,
      "text": " 약간 허용이라고 볼 수 있을 것 같아요."
    },
    {
      "id": 87,
      "start": 257.6,
      "end": 259.92,
      "text": " 자 이런 식으로 돌 들을"
    },
    {
      "id": 88,
      "start": 261.04,
      "end": 263.6,
      "text": " 질감을 찾아서 이런 거 당도해주고"
    },
    {
      "id": 89,
      "start": 266.32,
      "end": 268.0,
      "text": " 그쵸 약간 이렇게 가는 거죠."
    },
    {
      "id": 90,
      "start": 268.0,
      "end": 270.48,
      "text": " 이렇게 하면 약간 콜라주 아트를 한 것처럼"
    },
    {
      "id": 91,
      "start": 270.48,
      "end": 273.52,
      "text": " 조금 나름 재밌는 그런 형상이 나오고"
    },
    {
      "id": 92,
      "start": 274.56,
      "end": 276.32,
      "text": " 배경을 한 번 베리에이션 좀 해볼게요."
    },
    {
      "id": 93,
      "start": 276.48,
      "end": 278.48,
      "text": " 배경을 블랙으로 가고"
    },
    {
      "id": 94,
      "start": 280.64,
      "end": 282.48,
      "text": " 이 요소들을 다 골라서"
    },
    {
      "id": 95,
      "start": 283.28,
      "end": 285.28,
      "text": " 그냥 화이트로 하게 된다면 어떨까."
    },
    {
      "id": 96,
      "start": 285.28,
      "end": 287.28,
      "text": " 자 둘 중에 뭐가 나는 것 같아요."
    },
    {
      "id": 97,
      "start": 287.28,
      "end": 289.44,
      "text": " 제가 보기에는 블랙을 그냥"
    },
    {
      "id": 98,
      "start": 289.44,
      "end": 290.8,
      "text": " 여기다 쓰는 게 나는 것 같아서"
    },
    {
      "id": 99,
      "start": 290.8,
      "end": 292.24,
      "text": " 이렇게 냅두도 갈게요."
    },
    {
      "id": 100,
      "start": 292.24,
      "end": 294.24,
      "text": " 자 이렇게 해주시고"
    },
    {
      "id": 101,
      "start": 294.24,
      "end": 295.76,
      "text": " 자 여기서 약간 이제"
    },
    {
      "id": 102,
      "start": 295.76,
      "end": 297.76,
      "text": " 재밌는 포인트를 써주면은"
    },
    {
      "id": 103,
      "start": 297.76,
      "end": 300.0,
      "text": " 여기 이런 선분들에다가"
    },
    {
      "id": 104,
      "start": 300.0,
      "end": 301.44,
      "text": " 텍스트를 써주는 거예요."
    },
    {
      "id": 105,
      "start": 301.44,
      "end": 302.96,
      "text": " 얘는 중간에 들어갔죠."
    },
    {
      "id": 106,
      "start": 302.96,
      "end": 306.15999999999997,
      "text": " 근데 이번에는 조금 약간 역발상을 하는 거죠."
    },
    {
      "id": 107,
      "start": 306.32000000000005,
      "end": 307.92,
      "text": " 자 이렇게 해서"
    },
    {
      "id": 108,
      "start": 312.56,
      "end": 315.76000000000005,
      "text": " 여기서 뿜트는 영화가 잠깐 들어갔으니까"
    },
    {
      "id": 109,
      "start": 315.76000000000005,
      "end": 319.28000000000003,
      "text": " 제 좋아하는 멀리 싱크 센스 같은 거를"
    },
    {
      "id": 110,
      "start": 319.28000000000003,
      "end": 320.8,
      "text": " 자 이렇게 해서"
    },
    {
      "id": 111,
      "start": 322.16,
      "end": 325.36,
      "text": " 영화는 자관을 굳이 안 줄여줘도 됩니다."
    },
    {
      "id": 112,
      "start": 326.48,
      "end": 328.96000000000004,
      "text": " 이거 각도를 잘 맞춰서"
    },
    {
      "id": 113,
      "start": 328.96000000000004,
      "end": 331.76000000000005,
      "text": " 이런 데다가 이제 하나씩 배치려주는 거예요."
    },
    {
      "id": 114,
      "start": 333.44000000000005,
      "end": 334.96000000000004,
      "text": " 자 이렇게"
    },
    {
      "id": 115,
      "start": 335.12,
      "end": 336.64,
      "text": " 자 여기서도"
    },
    {
      "id": 116,
      "start": 341.03999999999996,
      "end": 343.03999999999996,
      "text": " 이런 식으로 가는 거죠."
    },
    {
      "id": 117,
      "start": 343.68,
      "end": 346.08,
      "text": " 자 여기서는 약간 여기에 맞춰서"
    },
    {
      "id": 118,
      "start": 349.59999999999997,
      "end": 351.28,
      "text": " 스톤 엔디스 5.0"
    },
    {
      "id": 119,
      "start": 351.28,
      "end": 353.28,
      "text": " 뭔 뜻인지 모르겠어요."
    },
    {
      "id": 120,
      "start": 353.91999999999996,
      "end": 355.2,
      "text": " 이 진지 모르겠는데"
    },
    {
      "id": 121,
      "start": 355.2,
      "end": 357.59999999999997,
      "text": " 뭔가 브랜드 이름 같기도 하고 그렇죠."
    },
    {
      "id": 122,
      "start": 358.24,
      "end": 359.52,
      "text": " 자 이렇게"
    },
    {
      "id": 123,
      "start": 359.91999999999996,
      "end": 361.52,
      "text": " 이런 식으로 하나씩 넣어주는 거예요."
    },
    {
      "id": 124,
      "start": 361.52,
      "end": 362.96,
      "text": " 여기도 하나 넣어줄게요."
    },
    {
      "id": 125,
      "start": 362.96,
      "end": 364.4,
      "text": " 이렇게 한번 넣어볼까요?"
    },
    {
      "id": 126,
      "start": 365.2,
      "end": 366.23999999999995,
      "text": " 이공이 요."
    },
    {
      "id": 127,
      "start": 368.71999999999997,
      "end": 370.23999999999995,
      "text": " 자 여기 이렇게"
    },
    {
      "id": 128,
      "start": 374.32,
      "end": 375.52,
      "text": " 자 이렇게 들어가고죠."
    },
    {
      "id": 129,
      "start": 376.23999999999995,
      "end": 377.76,
      "text": " 이런 식으로 이제"
    },
    {
      "id": 130,
      "start": 377.76,
      "end": 380.08,
      "text": " 쭉쭉한 식치고 넣어주면"
    },
    {
      "id": 131,
      "start": 383.35999999999996,
      "end": 385.35999999999996,
      "text": " 아 재밌는 느낌이 확 납니다."
    },
    {
      "id": 132,
      "start": 385.76,
      "end": 387.67999999999995,
      "text": " 오히려 디자이너들은 이렇게"
    },
    {
      "id": 133,
      "start": 387.67999999999995,
      "end": 389.52,
      "text": " 약간 키치함을 살려서"
    },
    {
      "id": 134,
      "start": 390.0,
      "end": 392.08,
      "text": " 이런 로아한 느낌을"
    },
    {
      "id": 135,
      "start": 392.15999999999997,
      "end": 393.84,
      "text": " 냄겨 듣는 경우도 많죠."
    },
    {
      "id": 136,
      "start": 393.84,
      "end": 395.84,
      "text": " 자 그런 거를 좀 사용을 하는 거예요."
    },
    {
      "id": 137,
      "start": 402.08,
      "end": 404.56,
      "text": " 자 이렇게 알 수 없는 텍스트들 좀 몇 개 넣어주고"
    },
    {
      "id": 138,
      "start": 406.88,
      "end": 408.0,
      "text": " 자 이렇게 하는 거죠."
    },
    {
      "id": 139,
      "start": 408.0,
      "end": 412.08,
      "text": " 자 뭔가 벌써 좀 약간 구경이 포스터 느낀 나잖아요. 그렇죠."
    },
    {
      "id": 140,
      "start": 412.08,
      "end": 413.59999999999997,
      "text": " 자 이런 식으로 하는 겁니다."
    },
    {
      "id": 141,
      "start": 414.08,
      "end": 416.08,
      "text": " 여기 약간 심심하다가 싶으시면은"
    },
    {
      "id": 142,
      "start": 416.08,
      "end": 419.36,
      "text": " 쓸 때 없는 거 별 같은 거 하나 이렇게 추가해주는 센스"
    },
    {
      "id": 143,
      "start": 420.08,
      "end": 421.52,
      "text": " 자 여기다가 이렇게"
    },
    {
      "id": 144,
      "start": 422.32,
      "end": 424.56,
      "text": " 이렇게 약간 그냥 별 의미 없는 것들"
    },
    {
      "id": 145,
      "start": 424.56,
      "end": 425.59999999999997,
      "text": " 하나씩 넣어주는 거예요."
    },
    {
      "id": 146,
      "start": 426.96,
      "end": 428.0,
      "text": " 그래서"
    },
    {
      "id": 147,
      "start": 428.0,
      "end": 431.59999999999997,
