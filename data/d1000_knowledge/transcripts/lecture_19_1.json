    {
      "id": 62,
      "start": 190.0,
      "end": 192.0,
      "text": " 보통 나무를 뜻하는거 같은데"
    },
    {
      "id": 63,
      "start": 193.0,
      "end": 194.0,
      "text": " 자, 올려준 다음에"
