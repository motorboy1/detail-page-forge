      "end": 134.56,
      "text": " 이렇게"
    },
    {
      "id": 60,
      "start": 134.56,
      "end": 135.56,
      "text": " 그렇죠"
    },
    {
      "id": 61,
      "start": 135.56,
      "end": 137.56,
      "text": " 그리고 하나 더"
