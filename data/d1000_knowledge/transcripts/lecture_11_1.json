      "start": 334.16,
      "end": 335.16,
      "text": " 자, 텍스트는"
    },
    {
      "id": 117,
      "start": 341.16,
      "end": 342.16,
      "text": " 대치"
    },
    {
      "id": 118,
      "start": 342.16,
      "end": 344.16,
      "text": " 라는 단어를 썼는데요"
    },
    {
      "id": 119,
      "start": 345.16,
      "end": 348.16,
      "text": " 요런 폰트, 요런 구도에서는"
    },
    {
      "id": 120,
      "start": 348.16,
      "end": 350.16,
      "text": " 약간 이제 명조체도 조금"
    },
    {
      "id": 121,
      "start": 350.16,
      "end": 352.16,
      "text": " 생각을 해볼 필요가 있겠죠"
    },
    {
      "id": 122,
      "start": 352.16,
      "end": 353.16,
      "text": " 아무래도"
    },
    {
      "id": 123,
      "start": 353.16,
      "end": 355.16,
      "text": " 전반적으로 느낌이"
    },
    {
      "id": 124,
      "start": 355.16,
      "end": 357.16,
      "text": " 약간 클래식한 느낌이 나니까"
    },
    {
      "id": 125,
      "start": 357.16,
      "end": 360.16,
      "text": " 제주 명조 한번 써볼까요"
    },
    {
      "id": 126,
      "start": 360.16,
      "end": 362.16,
      "text": " 자, 제주 명조, 이거 괜찮은 것 같아요"
    },
    {
      "id": 127,
      "start": 362.16,
      "end": 365.16,
      "text": " 그리고 자가를 확 좀 줄여주고"
    },
    {
      "id": 128,
      "start": 367.16,
      "end": 368.16,
      "text": " 요런 식으로"
    },
    {
      "id": 129,
      "start": 368.16,
      "end": 370.16,
      "text": " 자, 괜찮죠? 요번트는"
    },
    {
      "id": 130,
      "start": 371.16,
      "end": 372.16,
      "text": " 자, 대치"
    },
    {
      "id": 131,
      "start": 372.16,
      "end": 374.16,
      "text": " 자, 대치라는 거"
    },
    {
      "id": 132,
      "start": 374.16,
      "end": 376.16,
      "text": " 뭐 한자랑까? 뭔지 모르겠는데요"
    },
    {
      "id": 133,
      "start": 376.16,
      "end": 378.16,
      "text": " 나머거나 써볼까 한자는"
    },
    {
      "id": 134,
      "start": 380.16,
      "end": 381.16,
      "text": " 정"
    },
    {
      "id": 135,
      "start": 383.16,
      "end": 384.16,
      "text": " 이거 쓰고"
    },
    {
      "id": 136,
      "start": 384.16,
      "end": 386.16,
      "text": " 여기서 옵션엔턴가"
    },
    {
      "id": 137,
      "start": 388.16,
      "end": 389.16,
      "text": " 컨트롤엔턴가요?"
    },
    {
      "id": 138,
      "start": 397.16,
      "end": 400.16,
      "text": " 자, 뭐 한자 단축기가 뭔지는 모르겠으니까"
    },
    {
      "id": 139,
      "start": 402.16,
      "end": 404.16,
      "text": " 자, 자, 자, 먹을게요"
    },
    {
      "id": 140,
      "start": 406.16,
      "end": 407.16,
      "text": " 맥"
    },
    {
      "id": 141,
      "start": 407.16,
      "end": 408.16,
      "text": " 단자 단축기"
    },
    {
      "id": 142,
      "start": 411.16,
      "end": 413.16,
      "text": " 옵션 플러스 엔터라고 하는데"
    },
    {
      "id": 143,
      "start": 418.16,
      "end": 421.16,
      "text": " 뭔가 안 되는 느낌"
    },
    {
      "id": 144,
      "start": 427.16,
      "end": 428.16,
      "text": " 옵션엔턴"
    },
    {
      "id": 145,
      "start": 434.16,
      "end": 436.16,
      "text": " 뭔가 안 되는 것 같으니까 일단은 빼줄게요"
    },
    {
      "id": 146,
      "start": 436.16,
      "end": 438.16,
      "text": " 자, 아무튼 뭐 대치라고 썼고요"
    },
    {
      "id": 147,
      "start": 439.16,
      "end": 441.16,
      "text": " 자, 여기 폰트를 조금 더"
    },
    {
      "id": 148,
      "start": 441.16,
      "end": 443.16,
      "text": " 예쁘게 다듬어보고 싶긴 한데"
    },
    {
      "id": 149,
      "start": 443.16,
      "end": 444.16,
      "text": " 그게 될지는 모르겠어요"
    },
    {
      "id": 150,
      "start": 444.16,
      "end": 445.16,
      "text": " 일단"
    },
    {
      "id": 151,
      "start": 445.16,
      "end": 446.16,
      "text": " 커멘디이 눌러서"
    },
    {
      "id": 152,
      "start": 446.16,
      "end": 447.16,
      "text": " 얘를 그냥"
    },
    {
      "id": 153,
      "start": 447.16,
      "end": 448.16,
      "text": " 변형을 해주고"
    },
    {
      "id": 154,
      "start": 450.16,
      "end": 452.16,
      "text": " 여기서"
    },
    {
      "id": 155,
      "start": 452.16,
      "end": 453.16,
      "text": " 뭐 예를 들어서"
    },
    {
      "id": 156,
      "start": 453.16,
      "end": 454.16,
      "text": " 여기 이런 부분 있죠"
    },
    {
      "id": 157,
      "start": 454.16,
      "end": 455.16,
      "text": " 이런 부분을 약간"
    },
    {
      "id": 158,
      "start": 455.16,
      "end": 457.16,
      "text": " 내려 보는 것도 괜찮을 것 같아요"
    },
    {
      "id": 159,
      "start": 457.16,
      "end": 458.16,
      "text": " 여기를"
    },
    {
      "id": 160,
      "start": 458.16,
      "end": 460.16,
      "text": " 이렇게 내린다면은 어떻게 될까"
    },
    {
      "id": 161,
      "start": 460.16,
      "end": 461.16,
      "text": " 자, 이러면은"
    },
    {
      "id": 162,
      "start": 461.16,
      "end": 462.16,
      "text": " 어, 괜찮죠?"
    },
    {
      "id": 163,
      "start": 462.16,
      "end": 464.16,
      "text": " 뭔가 흘러내리는 느낌"
    },
    {
      "id": 164,
      "start": 464.16,
      "end": 465.16,
      "text": " 좀 나면서"
    },
    {
      "id": 165,
      "start": 465.16,
      "end": 466.16,
      "text": " 어, 괜찮아 보여"
    },
    {
      "id": 166,
      "start": 466.16,
      "end": 467.16,
      "text": " 제가 보기엔"
    },
    {
      "id": 167,
      "start": 467.16,
      "end": 468.16,
      "text": " 좋습니다"
    },
    {
      "id": 168,
      "start": 468.16,
      "end": 470.16,
      "text": " 이런 식으로 약간 다듬어주는 것도"
    },
    {
      "id": 169,
      "start": 470.16,
      "end": 471.16,
      "text": " 가능할 것 같아요"
    },
    {
      "id": 170,
      "start": 473.16,
      "end": 474.16,
      "text": " 뭐, 여기를 이렇게 올릴 수도 있을까요?"
    },
    {
      "id": 171,
      "start": 476.16,
      "end": 478.16,
      "text": " 네, 어, 이것도"
    },
    {
      "id": 172,
      "start": 478.16,
      "end": 479.16,
      "text": " 괜찮네요"
    },
    {
      "id": 173,
      "start": 483.16,
      "end": 484.16,
      "text": " 살짝 옆으로"
    },
    {
      "id": 174,
      "start": 484.16,
      "end": 486.16,
      "text": " 공겨줄게요"
    },
    {
      "id": 175,
      "start": 490.16,
      "end": 492.16,
      "text": " 자, 이렇게 하면은 뭔가"
    },
    {
      "id": 176,
      "start": 492.16,
      "end": 494.16,
      "text": " 흘러내리는 느낌도 나면서"
    },
    {
      "id": 177,
      "start": 494.16,
      "end": 495.16,
      "text": " 조금 재밌는"
    },
    {
      "id": 178,
      "start": 495.16,
      "end": 496.16,
      "text": " 그런 조형이"
    },
    {
      "id": 179,
      "start": 496.16,
      "end": 497.16,
      "text": " 좀 완성이 된 거예요"
    },
    {
      "id": 180,
      "start": 497.16,
      "end": 498.16,
      "text": " 자, 한글은 뭐"
    },
    {
      "id": 181,
      "start": 498.16,
      "end": 500.16,
      "text": " 이게 거창하게 생각하실 필요 없고"
    },
    {
      "id": 182,
      "start": 500.16,
      "end": 501.16,
      "text": " 이런 식으로"
    },
    {
      "id": 183,
      "start": 501.16,
      "end": 503.16,
      "text": " 그냥 베이징한 폰트에다가"
    },
    {
      "id": 184,
      "start": 503.16,
      "end": 504.16,
      "text": " 약간의 효과 정도"
    },
    {
      "id": 185,
      "start": 504.16,
      "end": 506.16,
      "text": " 겨트리어주신다라고 생각을 하시면은"
    },
    {
      "id": 186,
      "start": 506.16,
      "end": 508.16,
      "text": " 다루기 열심히 편할 겁니다"
    },
    {
      "id": 187,
      "start": 508.16,
      "end": 509.16,
      "text": " 좋아요, 이렇게 해주고"
    },
    {
      "id": 188,
      "start": 511.16,
      "end": 514.1600000000001,
      "text": " 이제 자잘한 요소들을 좀 넣어주면 좋겠죠"
    },
    {
      "id": 189,
      "start": 514.1600000000001,
      "end": 515.1600000000001,
      "text": " 이런 분, 이런"
    },
    {
      "id": 190,
      "start": 515.1600000000001,
      "end": 516.1600000000001,
      "text": " 구도에다가"
    },
    {
      "id": 191,
      "start": 517.1600000000001,
      "end": 519.1600000000001,
      "text": " 자, 뭐 이런 것들을 좀 넣어줄 건데"
    },
    {
      "id": 192,
      "start": 521.1600000000001,
      "end": 523.1600000000001,
      "text": " 어, 여기다는"
    },
    {
      "id": 193,
      "start": 523.1600000000001,
      "end": 525.1600000000001,
      "text": " 자, 얘네를 살짝 내려서"
    },
    {
      "id": 194,
      "start": 526.1600000000001,
      "end": 528.1600000000001,
      "text": " 공간을 좀 더 확볼 해주고"
    },
    {
      "id": 195,
      "start": 529.1600000000001,
      "end": 531.1600000000001,
      "text": " 자, 여기 양쪽으로 한 번"
    },
    {
      "id": 196,
      "start": 531.1600000000001,
      "end": 532.1600000000001,
      "text": " 이렇게"
    },
    {
      "id": 197,
      "start": 532.16,
      "end": 533.16,
      "text": " 텍스트를 이렇게 넣어볼게요"
    },
    {
      "id": 198,
      "start": 533.16,
      "end": 534.16,
      "text": " 이렇게"
    },
    {
      "id": 199,
      "start": 534.16,
      "end": 535.16,
      "text": " 자, 이렇게 넣으면은 또 깔끔한"
    },
    {
      "id": 200,
      "start": 535.16,
      "end": 536.16,
      "text": " 대체가 나오겠죠"
    },
    {
      "id": 201,
      "start": 536.16,
      "end": 537.16,
      "text": " 좋아요"
    },
    {
      "id": 202,
      "start": 537.16,
      "end": 538.16,
      "text": " 그러면은"
    },
    {
      "id": 203,
      "start": 543.16,
      "end": 544.16,
      "text": " 자, 형과"
    },
    {
      "id": 204,
      "start": 546.16,
      "end": 548.16,
      "text": " 본태 대치"
    },
    {
      "id": 205,
      "start": 548.16,
      "end": 549.16,
      "text": " 본태에 대한"
    },
    {
      "id": 206,
      "start": 549.16,
      "end": 550.16,
      "text": " 당"
    },
    {
      "id": 207,
      "start": 550.16,
      "end": 552.16,
      "text": " 자, 또 무슨 소리인지 모르겠죠, 전혀"
    },
    {
      "id": 208,
      "start": 554.16,
      "end": 555.16,
      "text": " 서해해해"
    },
    {
      "id": 209,
      "start": 558.16,
      "end": 559.16,
      "text": " 아, 이거는"
    },
    {
      "id": 210,
      "start": 559.16,
      "end": 560.16,
      "text": " 대치에"
    },
    {
      "id": 211,
      "start": 560.16,
      "end": 561.16,
      "text": " 야"
    },
    {
      "id": 212,
      "start": 564.16,
      "end": 566.16,
      "text": " 자, 전혀 무슨 소리인지 모르겠고요"
    },
    {
      "id": 213,
      "start": 567.16,
      "end": 569.16,
      "text": " 무슨 소리인지 모르겠으나"
    },
    {
      "id": 214,
      "start": 569.16,
      "end": 570.16,
      "text": " 일단 써본 거예요"
    },
    {
      "id": 215,
      "start": 571.16,
      "end": 572.16,
      "text": " 텍스트에"
    },
    {
      "id": 216,
      "start": 577.16,
      "end": 579.16,
      "text": " 자, 난 뭐라고라고 막 썼어요"
    },
    {
      "id": 217,
      "start": 579.16,
      "end": 581.16,
      "text": " 전혀 뭔 뜻인지 모르겠어요"
    },
    {
      "id": 218,
      "start": 581.16,
      "end": 583.16,
      "text": " 자, 한 번 얘도 한 번"
    },
    {
      "id": 219,
      "start": 583.16,
      "end": 585.16,
      "text": " 명주를 넣었을 때 어떨지 한 번"
    },
    {
      "id": 220,
      "start": 586.16,
      "end": 587.16,
      "text": " 생각을 해볼게요"
    },
    {
      "id": 221,
      "start": 588.16,
      "end": 589.16,
      "text": " 자, 이런 식으로"
    },
    {
      "id": 222,
      "start": 589.16,
      "end": 591.16,
      "text": " 아, 근데 이거는 오히려 이렇게"
    },
    {
      "id": 223,
      "start": 591.16,
      "end": 594.16,
      "text": " 이렇게 고딩체로 들어가는 게 나아 보입니다, 그렇죠"
    },
    {
      "id": 224,
      "start": 594.16,
      "end": 595.16,
      "text": " 자, 이렇게 해서"
    },
    {
      "id": 225,
      "start": 596.16,
      "end": 598.16,
      "text": " 어, 주황정려를 좀 해주고 싶은데"
    },
    {
      "id": 226,
      "start": 600.16,
      "end": 603.16,
      "text": " 여기서 얘네를 살짝 위로 올려줄게요"
    },
    {
      "id": 227,
      "start": 603.16,
      "end": 606.16,
      "text": " 자, 딕쯤에서 주황정려 되게"
    },
    {
      "id": 228,
      "start": 607.16,
      "end": 608.16,
      "text": " 왜냐하면 얘가 이제"
    },
    {
      "id": 229,
      "start": 608.16,
      "end": 609.16,
      "text": " 눌리적으로는"
    },
    {
      "id": 230,
      "start": 609.16,
      "end": 610.16,
      "text": " 여기까지가 있기 때문에"
    },
    {
      "id": 231,
      "start": 610.16,
      "end": 611.16,
      "text": " 중앙이 여기 찜일 거예요"
    },
    {
      "id": 232,
      "start": 611.16,
      "end": 612.16,
      "text": " 근데"
    },
    {
      "id": 233,
      "start": 612.16,
      "end": 614.16,
      "text": " 이것 때문에 아래까지 좀 내려가는 거잖아요"
    },
    {
      "id": 234,
      "start": 614.16,
      "end": 615.16,
      "text": " 그래서 얘"
    },
    {
      "id": 235,
      "start": 615.16,
      "end": 616.16,
      "text": " 이쪽은 사실 별로"
    },
    {
      "id": 236,
      "start": 616.16,
      "end": 618.16,
      "text": " 조형적인 무게감이 없는 거예요"
    },
    {
      "id": 237,
      "start": 618.16,
      "end": 619.16,
      "text": " 그래서 얘를 빼고"
    },
    {
      "id": 238,
      "start": 619.16,
      "end": 620.16,
      "text": " 무게 중심은 여기 찜으로"
    },
    {
      "id": 239,
      "start": 620.16,
      "end": 621.16,
      "text": " 맞춰주는 게"
    },
    {
      "id": 240,
      "start": 621.16,
      "end": 622.16,
      "text": " 울타"
    },
    {
      "id": 241,
      "start": 622.16,
      "end": 623.16,
      "text": " 라고 해주시면"
    },
    {
      "id": 242,
      "start": 623.16,
      "end": 624.16,
      "text": " 생각을 해주시면 될 것 같아요"
    },
    {
      "id": 243,
      "start": 624.16,
      "end": 625.16,
      "text": " 자, 좋습니다"
    },
    {
      "id": 244,
      "start": 625.16,
      "end": 626.16,
      "text": " 이렇게 하면 뭔가"
    },
    {
      "id": 245,
      "start": 626.16,
      "end": 628.16,
      "text": " 어, 그럴 수 한 또"
    },
    {
      "id": 246,
      "start": 628.16,
      "end": 629.16,
      "text": " 포사 나왔죠, 그렇죠"
    },
    {
      "id": 247,
      "start": 630.16,
      "end": 632.16,
      "text": " 자, 이런 식으로 S자로 활용을 하는 거예요"
    },
    {
      "id": 248,
      "start": 633.16,
      "end": 634.16,
      "text": " 어렵지 않습니다"
