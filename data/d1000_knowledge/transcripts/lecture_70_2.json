    {
      "id": 32,
      "start": 111.48,
      "end": 113.04,
      "text": " 보통 4개가 있는 것 같긴 해요."
    },
    {
      "id": 33,
      "start": 113.04,
      "end": 115.60000000000001,
      "text": " 그래서 4개로 한번 넣어보도록 하죠."
    },
    {
      "id": 34,
      "start": 115.60000000000001,
      "end": 120.04,
      "text": " 23.30까지."
    },
    {
      "id": 35,
      "start": 120.04,
      "end": 123.44,
      "text": " 이렇게 4개가 들어가면 조금 더 현실감이 있고요."
    },
    {
      "id": 36,
      "start": 123.44,
      "end": 126.72,
      "text": " 묶어주고 허리 좀 좁혀줄게요."
    },
    {
      "id": 37,
      "start": 126.72,
      "end": 130.36,
      "text": " 이거 두 개 있으면 일단 갑자기 스크린시타는 느낌이 나기 시작합니다."
    },
    {
      "id": 38,
      "start": 130.36,
      "end": 131.36,
      "text": " 그렇죠."
    },
    {
      "id": 39,
      "start": 131.36,
      "end": 132.56,
      "text": " 이렇게 해주고."
    },
    {
      "id": 40,
      "start": 132.56,
      "end": 137.28,
      "text": " 저 반대편에는 보통 무엇이 있느냐 생각을 해보면"
    },
    {
      "id": 41,
      "start": 137.28,
      "end": 138.96,
      "text": " 그게 있죠."
    },
    {
      "id": 42,
      "start": 138.96,
      "end": 141.72,
      "text": " 배터리 알콘."
    },
    {
      "id": 43,
      "start": 141.72,
      "end": 142.8,
      "text": " 보통 그 정도 있는 것 같아요."
    },
    {
      "id": 44,
      "start": 142.8,
      "end": 144.4,
      "text": " 배터리 알콘이."
    },
    {
      "id": 45,
      "start": 144.4,
      "end": 146.28,
      "text": " 배터리도 쉽죠."
    },
    {
      "id": 46,
      "start": 146.28,
      "end": 149.56,
      "text": " 대충 28 해주고"
    },
    {
      "id": 47,
      "start": 149.56,
      "end": 152.12,
      "text": " 여기 한 48 해주고"
    },
    {
      "id": 48,
      "start": 152.12,
      "end": 154.52,
      "text": " 살짝 돌려주고"
    },
    {
      "id": 49,
      "start": 154.52,
      "end": 157.84,
      "text": " 그리고 블랙을 빼주고요."
    },
    {
      "id": 50,
      "start": 157.84,
      "end": 159.2,
      "text": " 스토리 글에 넣어줄 거예요."
    },
    {
      "id": 51,
      "start": 159.2,
      "end": 160.08,
      "text": " 스토리 글에 넣었는데"
    },
    {
      "id": 52,
      "start": 160.08,
      "end": 162.8,
      "text": " 한 6정도 넣어주고"
    },
    {
      "id": 53,
      "start": 162.8,
      "end": 164.88,
      "text": " 그리고 이제 특정"
    },
    {
      "id": 54,
      "start": 164.88,
      "end": 167.08,
      "text": " 배터리가 찬 양만큼한"
