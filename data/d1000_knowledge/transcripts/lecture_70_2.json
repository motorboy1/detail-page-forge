    {
      "id": 96,
      "start": 254.56,
      "end": 256.6,
      "text": " 자, 그다음에 Shift A 해주고요."
    },
    {
      "id": 97,
      "start": 256.6,
      "end": 258.24,
      "text": " 40, 20"
