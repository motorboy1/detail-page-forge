    {
      "id": 62,
      "start": 179.64000000000001,
      "end": 181.92000000000002,
      "text": " 이거를 맞춰주면"
    },
    {
      "id": 63,
      "start": 181.92000000000002,
      "end": 184.60000000000002,
      "text": " 핸드폰 스킨시타가 맞는 것 같다."
