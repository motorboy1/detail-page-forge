    {
      "id": 65,
      "start": 186.76000000000002,
      "end": 187.92000000000002,
      "text": " 이런 느낌이들죠."
    },
    {
      "id": 66,
      "start": 187.92000000000002,
      "end": 189.20000000000002,
      "text": " 그리고 여기에 있는"
    },
    {
      "id": 67,
      "start": 189.20000000000002,
      "end": 192.36,
      "text": " 스토리 글에 4정도만 넣어봅시다."
