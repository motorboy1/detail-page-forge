    {
      "id": 120,
      "start": 318.84,
      "end": 322.2,
      "text": " 약간 무슨 느낌인지 아시겠죠."
    },
    {
      "id": 121,
      "start": 322.2,
      "end": 324.71999999999997,
      "text": " 이렇게 넣어주면 어느 정도"
