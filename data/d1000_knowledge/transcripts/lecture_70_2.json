    {
      "id": 74,
      "start": 206.44,
      "end": 208.28,
      "text": " 여기 좀 주황정도 안 만네요."
    },
    {
      "id": 75,
      "start": 208.28,
      "end": 210.28,
      "text": " 그러면 올려줍니다."
    },
    {
      "id": 76,
      "start": 210.28,
      "end": 211.68,
      "text": " 좋아요."
    },
    {
      "id": 77,
      "start": 211.68,
      "end": 213.84,
      "text": " 어차피 살짝 조금 어근 당기"
