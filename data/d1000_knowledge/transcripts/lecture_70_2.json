    {
      "id": 392,
      "start": 948.92,
      "end": 950.92,
      "text": " 멋있는 거 힙한 거 다 해봤자."
    },
    {
      "id": 393,
      "start": 950.92,
      "end": 951.92,
      "text": " 사실 이거 못 이겨요."
