    {
      "id": 99,
      "start": 260.36,
      "end": 261.44,
      "text": " 이렇게 띄워주고"
    },
    {
      "id": 100,
      "start": 261.44,
      "end": 262.4,
      "text": " 자, 뺄 넣어줍니다."
    },
    {
      "id": 101,
      "start": 262.4,
      "end": 264.96,
      "text": " 뺄 중에서 내 메시지를 강조할 건지"
