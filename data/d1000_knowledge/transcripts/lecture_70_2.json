    {
      "id": 69,
      "start": 195.08,
      "end": 197.68,
      "text": " 얘도 올려주고"
    },
    {
      "id": 70,
      "start": 197.68,
      "end": 199.48000000000002,
      "text": " 이렇게 잘되니까"
    },
    {
      "id": 71,
      "start": 199.48000000000002,
      "end": 202.64000000000001,
      "text": " 적당히 이렇게 넣어줍니다."
    },
    {
      "id": 72,
      "start": 202.64000000000001,
      "end": 203.52,
      "text": " 좋아요. 이 상황에서"
    },
    {
      "id": 73,
      "start": 203.52,
      "end": 206.44,
      "text": " 이제 저희가 해야 되는 거는"
