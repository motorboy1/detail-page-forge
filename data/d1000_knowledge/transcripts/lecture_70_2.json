    {
      "id": 87,
      "start": 230.0,
      "end": 233.07999999999998,
      "text": " 이거 만든 방법을 알려드릴게요."
    },
    {
      "id": 88,
      "start": 233.07999999999998,
      "end": 234.0,
      "text": " 자, 텍스트를 써요."
    },
    {
      "id": 89,
      "start": 234.0,
      "end": 235.35999999999999,
      "text": " 일단 여기 이제"
    },
    {
      "id": 90,
      "start": 235.35999999999999,
      "end": 239.2,
      "text": " 재밌는 텍스트 구성을 해 본 되겠죠."
    },
    {
      "id": 91,
      "start": 239.2,
      "end": 245.68,
      "text": " 아직도 이 모자 못 산 흙 없지."
    },
    {
      "id": 92,
      "start": 245.68,
      "end": 247.8,
      "text": " 이런 식으로 텍스트를 쓰고요."
    },
    {
      "id": 93,
      "start": 247.8,
      "end": 249.68,
      "text": " 크게는 좀 크게."
    },
    {
      "id": 94,
      "start": 249.68,
      "end": 252.16,
      "text": " 48정도면 괜찮을 것 같아요."
    },
    {
      "id": 95,
      "start": 252.16,
      "end": 254.56,
      "text": " 이거 마이너스 3% 해주고"
