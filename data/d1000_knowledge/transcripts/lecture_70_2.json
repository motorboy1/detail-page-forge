    {
      "id": 56,
      "start": 169.32000000000002,
      "end": 171.36,
      "text": " 배터리 알콘이 되는 거죠."
    },
    {
      "id": 57,
      "start": 171.36,
      "end": 172.16000000000003,
      "text": " 좋습니다."
    },
    {
      "id": 58,
      "start": 172.16000000000003,
      "end": 173.68,
      "text": " 이렇게 3개가 들어가면"
